@page
@model Clinic.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Appointments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0" id="headerTitle">Lịch khám hôm nay</h2>
        <div class="text-muted small" id="headerRange"></div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <div class="btn-group" role="group" aria-label="Chọn tuần">
            <button type="button" data-week="0" class="btn btn-sm btn-outline-secondary week-btn active">Hôm nay</button>
            <button type="button" data-week="1" class="btn btn-sm btn-outline-secondary week-btn">Tuần này</button>
            <button type="button" data-week="2" class="btn btn-sm btn-outline-secondary week-btn">Tuần kế tiếp</button>
            <button type="button" data-week="3" class="btn btn-sm btn-outline-secondary week-btn">2 tuần kế tiếp</button>
        </div>
        <a class="btn btn-sm btn-primary" href="/Appointments/Create">New Appointment</a>
    </div>
</div>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-4">
            <div class="position-relative">
                <input id="filterPatient" class="form-control" placeholder="Tìm theo tên hoặc SĐT bệnh nhân..." autocomplete="off" />
                <input type="hidden" id="filterPatientId" />
                <div id="patientDropdown" class="dropdown-menu w-100" style="max-height:250px;overflow-y:auto;"></div>
            </div>
            <div id="patientInfo" class="small text-muted mt-1" style="display:none;"></div>
        </div>
        <div class="col-md-2">
            <select class="form-select">
                <option>All doctors</option>
                <option>Dr. Tran Thi B</option>
                <option>Dr. Nguyen Van D</option>
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select">
                <option>All types</option>
                <option>Check-up</option>
                <option>Follow-up</option>
                <option>Emergency</option>
            </select>
        </div>
        <div class="col-md-2">
            <a href="javascript:void(0)" id="toggleAdvanced" class="small text-primary"><i class="bi bi-funnel me-1"></i>Tìm kiếm nâng cao</a>
        </div>
    </div>
    <div id="advancedSearch" class="row g-3 align-items-end mt-1" style="display:none;">
        <div class="col-md-2">
            <label class="form-label small mb-1">Từ ngày</label>
            <input type="date" id="filterDateFrom" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <label class="form-label small mb-1">Đến ngày</label>
            <input type="date" id="filterDateTo" class="form-control form-control-sm" />
        </div>
        <div class="col-md-2">
            <button type="button" id="btnClearAdvanced" class="btn btn-sm btn-outline-secondary">Xóa bộ lọc</button>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-12">
        <div class="card p-3">
            <h5 class="mb-3">Danh sách lịch khám</h5>
            <div class="table-responsive">
                <table id="appointmentsTable" class="table table-striped table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th>Ngày giờ</th>
                            <th>Bệnh nhân</th>
                            <th>Bác sĩ</th>
                            <th>Lý do</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-12">
        <div class="card p-3">
            <h5 class="mb-3">Lịch mổ</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>09:30</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="https://via.placeholder.com/44" class="rounded-circle me-2" alt="">
                                    <div>
                                        <div class="fw-semibold">Nguyen Van G</div>
                                        <div class="small text-muted">PT-00123</div>
                                    </div>
                                </div>
                            </td>
                            <td>Dr. Tran Thi B, Dr. Tran Thi C, Nurse. Tran Thi B</td>
                            <td>Room 201</td>
                            <td><span class="badge bg-success">Checked-in</span></td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="/Patients/Details?id=123">Details</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/moment@2.30.1/min/moment-with-locales.min.js"></script>
    <script>
        moment.locale('vi');
    </script>
    <style>
        #appointmentsTable {
            font-size: 0.875rem;
        }
            /* Header styling */
            #appointmentsTable thead {
                background-color: #f8f9fa;
                border-bottom: 2px solid #dee2e6;
            }

                #appointmentsTable thead th {
                    padding: 0.75rem;
                    vertical-align: middle;
                    font-weight: 600;
                    color: #212529;
                    border-bottom: 2px solid #dee2e6;
                    user-select: none;
                }

                    #appointmentsTable thead th:hover {
                        background-color: #e9ecef;
                    }
                    /* Sort icons */
                    #appointmentsTable thead th.sorting::after,
                    #appointmentsTable thead th.sorting_asc::after,
                    #appointmentsTable thead th.sorting_desc::after {
                        content: '';
                        margin-left: 0.5rem;
                    }
            /* Body row styling */
            #appointmentsTable tbody td {
                padding: 0.4rem 0.75rem;
                vertical-align: middle;
                border-bottom: 1px solid #dee2e6;
            }

            #appointmentsTable tbody tr:hover {
                background-color: #f8f9fa !important;
            }

            #appointmentsTable .small {
                font-size: 0.75rem;
            }

            #appointmentsTable .btn-sm {
                padding: 0.25rem 0.5rem;
                font-size: 0.75rem;
            }
        /* Footer info container */
        .dataTables_info {
            font-size: 0.8rem;
            white-space: nowrap;
        }
        /* Pagination on same line */
        .dataTables_wrapper .dataTables_paginate {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 0 !important;
            margin: 0 !important;
        }

            .dataTables_wrapper .dataTables_paginate .pagination {
                margin: 0;
                gap: 0 !important;
            }
        /* Footer layout */
        .dataTables_wrapper .dataTables_length {
            font-size: 0.8rem;
            margin: 0 !important;
        }

            .dataTables_wrapper .dataTables_length label {
                display: flex;
                align-items: center;
                gap: 0.3rem;
                margin: 0;
                white-space: nowrap;
                font-size: 0.8rem;
            }

            .dataTables_wrapper .dataTables_length select {
                padding: 0.2rem 1.5rem 0.2rem 0.4rem;
                font-size: 0.8rem;
                border: 1px solid #dee2e6;
                border-radius: 0.2rem;
                height: 28px;
                width: 60px;
            }
        /* Footer wrapper */
        .dataTables_wrapper {
            position: relative;
        }
            /* Footer row - single line ultra compact layout */
            .dataTables_wrapper .row:last-child {
                display: flex !important;
                align-items: center !important;
                justify-content: flex-start !important;
                flex-wrap: nowrap !important;
                padding: 0.5rem 0 !important;
                margin: 0 !important;
                border-top: 1px solid #dee2e6;
                width: 100%;
                min-height: 32px;
            }

                .dataTables_wrapper .row:last-child > div {
                    display: flex !important;
                    align-items: center !important;
                    flex-wrap: nowrap !important;
                    gap: 1rem !important;
                    flex: 1 1 auto;
                    max-width: 100% !important;
                    width: 100% !important;
                }
            /* Length selector */
            .dataTables_wrapper .dataTables_length {
                padding: 0 !important;
                margin: 0 !important;
                flex: 0 0 auto;
                order: 1;
            }
            /* Info text */
            .dataTables_wrapper .dataTables_info {
                padding: 0 !important;
                margin: 0 !important;
                flex: 1 1 auto;
                order: 2;
                text-align: center;
            }
            /* Pagination */
            .dataTables_wrapper .dataTables_paginate {
                padding: 0 !important;
                margin: 0 !important;
                flex: 0 0 auto;
                order: 3;
                gap: 0 !important;
            }

                .dataTables_wrapper .dataTables_paginate .pagination {
                    margin: 0;
                    gap: 0 !important;
                }

                .dataTables_wrapper .dataTables_paginate .paginate_button {
                    padding: 0.05rem 0.15rem;
                    font-size: 0.65rem;
                    min-width: 18px;
                    height: 18px;
                    line-height: 18px;
                    margin: 0 !important;
                    border-radius: 0.1rem;
                }

                .dataTables_wrapper .dataTables_paginate .pagination .page-item {
                    margin: 0 !important;
                }

                    .dataTables_wrapper .dataTables_paginate .pagination .page-item + .page-item .page-link {
                        margin-left: -1px !important;
                    }

                    .dataTables_wrapper .dataTables_paginate .pagination .page-item .page-link {
                        padding: 0.15rem 0.45rem !important;
                        font-size: 0.8rem !important;
                        line-height: 1.3 !important;
                        min-width: auto !important;
                        border-radius: 0 !important;
                    }

                    .dataTables_wrapper .dataTables_paginate .pagination .page-item:first-child .page-link {
                        border-top-left-radius: 0.2rem !important;
                        border-bottom-left-radius: 0.2rem !important;
                    }

                    .dataTables_wrapper .dataTables_paginate .pagination .page-item:last-child .page-link {
                        border-top-right-radius: 0.2rem !important;
                        border-bottom-right-radius: 0.2rem !important;
                    }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var filterTimeout = null;
            var activeWeekOffset = 0;

            function getWeekRange(offset) {
                var today = new Date();
                today.setHours(0,0,0,0);
                if (offset === 0) {
                    var ds = today.toISOString().split('T')[0];
                    return { from: ds, to: ds };
                }
                var day = today.getDay();
                var diffToMon = (day === 0 ? -6 : 1 - day);
                var monday = new Date(today);
                monday.setDate(today.getDate() + diffToMon + 7 * (offset - 1));
                var sunday = new Date(monday);
                sunday.setDate(monday.getDate() + 6);
                return { from: monday.toISOString().split('T')[0], to: sunday.toISOString().split('T')[0] };
            }

            function formatDateVN(dateStr) {
                var parts = dateStr.split('-');
                return parts[2] + '/' + parts[1];
            }
            function formatDateVNFull(dateStr) {
                var parts = dateStr.split('-');
                return parts[2] + '/' + parts[1] + '/' + parts[0];
            }

            var weekLabels = { 0: 'hôm nay', 1: 'tuần này', 2: 'tuần kế tiếp', 3: '2 tuần kế tiếp' };
            function updateHeader(offset) {
                var range = getWeekRange(offset);
                var h = document.getElementById('headerTitle');
                var sub = document.getElementById('headerRange');
                if (h) h.textContent = 'Lịch khám ' + (weekLabels[offset] || 'trong ' + offset + ' tuần nữa');
                if (sub) sub.textContent = offset === 0 ? '' : formatDateVN(range.from) + ' - ' + formatDateVNFull(range.to);
            }

            // Initialize DataTables for appointments pagination
            if (document.getElementById('appointmentsTable')) {
                $('#appointmentsTable').DataTable({
                    serverSide: true,
                    processing: true,
                    pageLength: 10,
                    paging: true,
                    searching: false,
                    ordering: true,
                    order: [[0, 'desc']], // Default sort by date descending
                    info: true,
                    language: {
                        url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json'
                    },
                    ajax: {
                        url: '/Index?handler=Appointments',
                        type: 'GET',
                        data: function(d) {
                            var patientId = document.getElementById('filterPatientId').value;
                            var patientText = document.getElementById('filterPatient').value.trim();
                            if (patientId) {
                                d.searchPatient = patientId;
                            } else if (patientText) {
                                d.searchPatient = patientText;
                            }
                            var dateFrom = document.getElementById('filterDateFrom').value;
                            var dateTo = document.getElementById('filterDateTo').value;
                            if (dateFrom || dateTo) {
                                d.searchDateFrom = dateFrom || dateTo;
                                d.searchDateTo = dateTo || dateFrom;
                            } else {
                                var range = getWeekRange(activeWeekOffset);
                                d.searchDateFrom = range.from;
                                d.searchDateTo = range.to;
                            }
                            return d;
                        },
                        dataSrc: 'data',
                        error: function (xhr, status, error) {
                            console.error('DataTables error:', error, xhr);
                        }
                    },
                    columns: [
                        {
                            data: 'scheduledAt',
                            className: 'fw-semibold',
                            render: function(data, type, row) {
                                if (!row.scheduledAtDisplay) return '-';
                                var m = moment(data, 'YYYY-MM-DD HH:mm');
                                var relative = m.isValid() ? m.fromNow() : '';
                                return '<div>' + row.scheduledAtDisplay + '</div><small class="text-muted">' + relative + '</small>';
                            },
                            orderable: true
                        },
                        {
                            data: null,
                            render: function(data) {
                                return '<div class="fw-semibold">' + data.patientName + '</div>' +
                                       '<div class="small text-muted">ID: ' + data.patientId + '</div>';
                            },
                            orderable: false
                        },
                        {
                            data: null,
                            render: function(data) {
                                return '<div class="fw-semibold">' + data.staffName + '</div>' +
                                       '<div class="small text-muted">ID: ' + data.staffId + '</div>';
                            },
                            orderable: false
                        },
                        {
                            data: 'reason',
                            orderable: true
                        },
                        {
                            data: null,
                            render: function(data) {
                                const statusColors = {
                                    'Scheduled': 'primary',
                                    'CheckedIn': 'info',
                                    'InProgress': 'warning',
                                    'Completed': 'success',
                                    'Cancelled': 'danger',
                                    'NoShow': 'secondary'
                                };
                                const color = statusColors[data.status] || 'secondary';
                                return '<span class="badge bg-' + color + '">' + data.status + '</span>';
                            },
                            orderable: true
                        },
                        {
                            data: null,
                            render: function(data) {
                                return '<a class="btn btn-sm btn-outline-primary" href="/Patients/Details?id=' + data.patientId + '">Chi tiết</a>';
                            },
                            orderable: false,
                            searchable: false
                        }
                    ],
                    dom: '<"row"<"col-sm-12"f>>rt<"row"<"col-sm-12"<"dataTables_length"l><"dataTables_info"i><"dataTables_paginate"p>>>',
                    drawCallback: function(settings) {
                        console.log('DataTables draw complete');
                    }
                });

                var table = $('#appointmentsTable').DataTable();

                // Week buttons
                document.querySelectorAll('.week-btn').forEach(function(btn) {
                    btn.addEventListener('click', function() {
                        document.querySelectorAll('.week-btn').forEach(function(b) { b.classList.remove('active'); });
                        btn.classList.add('active');
                        activeWeekOffset = parseInt(btn.dataset.week);
                        document.getElementById('filterDateFrom').value = '';
                        document.getElementById('filterDateTo').value = '';
                        updateHeader(activeWeekOffset);
                        table.ajax.reload();
                    });
                });

                // Patient autocomplete search
                var patientSearchInput = document.getElementById('filterPatient');
                var patientIdInput = document.getElementById('filterPatientId');
                var patientDropdown = document.getElementById('patientDropdown');
                var patientInfoEl = document.getElementById('patientInfo');
                var patientSearchTimeout = null;

                patientSearchInput.addEventListener('input', function() {
                    // Clear selection when user edits
                    if (patientIdInput.value) {
                        patientIdInput.value = '';
                        patientInfoEl.style.display = 'none';
                        table.ajax.reload();
                    }

                    clearTimeout(patientSearchTimeout);
                    var term = this.value.trim();
                    if (term.length < 2) {
                        patientDropdown.classList.remove('show');
                        // If cleared completely, reload to remove filter
                        if (term.length === 0) {
                            clearTimeout(filterTimeout);
                            filterTimeout = setTimeout(function() { table.ajax.reload(); }, 300);
                        }
                        return;
                    }
                    patientSearchTimeout = setTimeout(async function() {
                        try {
                            var res = await fetch('/Index?handler=SearchPatients&term=' + encodeURIComponent(term));
                            var data = await res.json();
                            patientDropdown.innerHTML = '';
                            if (data.length === 0) {
                                patientDropdown.innerHTML = '<div class="dropdown-item text-muted">Không tìm thấy</div>';
                            } else {
                                data.forEach(function(p) {
                                    var item = document.createElement('a');
                                    item.className = 'dropdown-item';
                                    item.href = 'javascript:void(0)';
                                    item.innerHTML = '<div class="fw-semibold">' + p.fullName + '</div><div class="small text-muted">ID: ' + p.id + (p.phone ? ' · ' + p.phone : '') + ' · ' + p.dateOfBirth + '</div>';
                                    item.addEventListener('click', function() {
                                        patientIdInput.value = p.id;
                                        patientSearchInput.value = p.fullName;
                                        patientInfoEl.textContent = 'ID: ' + p.id + (p.phone ? ' · SĐT: ' + p.phone : '') + ' · Ngày sinh: ' + p.dateOfBirth;
                                        patientInfoEl.style.display = '';
                                        patientDropdown.classList.remove('show');
                                        table.ajax.reload();
                                    });
                                    patientDropdown.appendChild(item);
                                });
                            }
                            patientDropdown.classList.add('show');
                        } catch(err) {
                            console.error('Error searching patients:', err);
                        }
                    }, 300);
                });

                // Close dropdown on outside click
                document.addEventListener('click', function(e) {
                    if (!patientSearchInput.contains(e.target) && !patientDropdown.contains(e.target)) {
                        patientDropdown.classList.remove('show');
                    }
                });

                // Advanced search toggle
                document.getElementById('toggleAdvanced').addEventListener('click', function() {
                    var panel = document.getElementById('advancedSearch');
                    var isHidden = panel.style.display === 'none';
                    panel.style.display = isHidden ? '' : 'none';
                    this.innerHTML = isHidden
                        ? '<i class="bi bi-funnel-fill me-1"></i>Ẩn tìm kiếm nâng cao'
                        : '<i class="bi bi-funnel me-1"></i>Tìm kiếm nâng cao';
                });

                // Advanced date filters
                document.getElementById('filterDateFrom').addEventListener('change', function() {
                    if (this.value) {
                        document.querySelectorAll('.week-btn').forEach(function(b) { b.classList.remove('active'); });
                    }
                    table.ajax.reload();
                });
                document.getElementById('filterDateTo').addEventListener('change', function() {
                    if (this.value) {
                        document.querySelectorAll('.week-btn').forEach(function(b) { b.classList.remove('active'); });
                    }
                    table.ajax.reload();
                });

                // Clear advanced filters
                document.getElementById('btnClearAdvanced').addEventListener('click', function() {
                    document.getElementById('filterDateFrom').value = '';
                    document.getElementById('filterDateTo').value = '';
                    // Re-activate default week button
                    document.querySelectorAll('.week-btn').forEach(function(b) { b.classList.remove('active'); });
                    document.querySelector('.week-btn[data-week="0"]').classList.add('active');
                    activeWeekOffset = 0;
                    updateHeader(activeWeekOffset);
                    table.ajax.reload();
                });

                // Initial load with default week
                updateHeader(activeWeekOffset);
            }
        });
    </script>
}