@page
@model Clinic.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Appointments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">
            Lịch khám
            @if (Model.WeekOffset == 0)
            {
                @:hôm nay
            }
            else if (Model.WeekOffset == 1)
            {
                @:tuần này
            }
            else if (Model.WeekOffset == 2)
            {
                @:tuần kế tiếp
            }
            else if (Model.WeekOffset == 3)
            {
                @:2 tuần kế tiếp
            }
            else if (Model.WeekOffset > 3)
            {
                @:trong @Model.WeekOffset tuần nữa
            }
        </h2>
        <div class="text-muted small">
            @Model.StartOfWeek.ToString("dd/MM") - @Model.EndOfWeek.ToString("dd/MM/yyyy")
        </div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <div class="btn-group" role="group" aria-label="Chọn tuần">
            <a asp-page="./Index" asp-route-weekOffset="0" class="btn btn-sm btn-outline-secondary @(Model.WeekOffset == 0 ? "active" : "")">Hôm nay</a>
            <a asp-page="./Index" asp-route-weekOffset="1" class="btn btn-sm btn-outline-secondary @(Model.WeekOffset == 1 ? "active" : "")">Tuần này</a>
            <a asp-page="./Index" asp-route-weekOffset="2" class="btn btn-sm btn-outline-secondary @(Model.WeekOffset == 2 ? "active" : "")">Tuần kế tiếp</a>
            <a asp-page="./Index" asp-route-weekOffset="3" class="btn btn-sm btn-outline-secondary @(Model.WeekOffset == 3 ? "active" : "")">2 tuần kế tiếp</a>
        </div>
        <a class="btn btn-sm btn-primary" href="/Appointments/Create">New Appointment</a>
    </div>
</div>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-4">
            <input class="form-control" placeholder="Search by patient name or ID" />
        </div>
        <div class="col-md-2">
            <input type="date" class="form-control" />
        </div>
        <div class="col-md-2">
            <select class="form-select">
                <option>All doctors</option>
                <option>Dr. Tran Thi B</option>
                <option>Dr. Nguyen Van D</option>
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select">
                <option>All types</option>
                <option>Check-up</option>
                <option>Follow-up</option>
                <option>Emergency</option>
            </select>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-12">
        <div class="card p-3">
            <h5 class="mb-3">Danh sách lịch khám (tất cả)</h5>
            <div class="table-responsive">
                <table id="appointmentsTable" class="table table-striped table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th>Ngày giờ</th>
                            <th>Bệnh nhân</th>
                            <th>Bác sĩ</th>
                            <th>Lý do</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<br />
<br />
<div class="row g-4">
    <div class="col-lg-12">
        <div class="card p-3">
            <h5 class="mb-3">Lịch mổ</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>09:30</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="https://via.placeholder.com/44" class="rounded-circle me-2" alt="">
                                    <div>
                                        <div class="fw-semibold">Nguyen Van G</div>
                                        <div class="small text-muted">PT-00123</div>
                                    </div>
                                </div>
                            </td>
                            <td>Dr. Tran Thi B, Dr. Tran Thi C, Nurse. Tran Thi B</td>
                            <td>Room 201</td>
                            <td><span class="badge bg-success">Checked-in</span></td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="/Patients/Details?id=123">Details</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/moment@2.30.1/min/moment-with-locales.min.js"></script>
    <script>
        moment.locale('vi');
    </script>
    <style>
        #appointmentsTable {
            font-size: 0.875rem;
        }
        /* Header styling */
        #appointmentsTable thead {
            background-color: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
        }
        #appointmentsTable thead th {
            padding: 0.75rem;
            vertical-align: middle;
            font-weight: 600;
            color: #212529;
            border-bottom: 2px solid #dee2e6;
            user-select: none;
        }
        #appointmentsTable thead th:hover {
            background-color: #e9ecef;
        }
        /* Sort icons */
        #appointmentsTable thead th.sorting::after,
        #appointmentsTable thead th.sorting_asc::after,
        #appointmentsTable thead th.sorting_desc::after {
            content: '';
            margin-left: 0.5rem;
        }
        /* Body row styling */
        #appointmentsTable tbody td {
            padding: 0.4rem 0.75rem;
            vertical-align: middle;
            border-bottom: 1px solid #dee2e6;
        }
        #appointmentsTable tbody tr:hover {
            background-color: #f8f9fa !important;
        }
        #appointmentsTable .small {
            font-size: 0.75rem;
        }
        #appointmentsTable .btn-sm {
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
        }
        /* Footer info container */
        .dataTables_info {
            font-size: 0.8rem;
            white-space: nowrap;
        }
        /* Pagination on same line */
        .dataTables_wrapper .dataTables_paginate {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 0 !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination {
            margin: 0;
            gap: 0 !important;
        }
        /* Footer layout */
        .dataTables_wrapper .dataTables_length {
            font-size: 0.8rem;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_length label {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            margin: 0;
            white-space: nowrap;
            font-size: 0.8rem;
        }
        .dataTables_wrapper .dataTables_length select {
            padding: 0.2rem 1.5rem 0.2rem 0.4rem;
            font-size: 0.8rem;
            border: 1px solid #dee2e6;
            border-radius: 0.2rem;
            height: 28px;
            width: 60px;
        }
        /* Footer wrapper */
        .dataTables_wrapper {
            position: relative;
        }
        /* Footer row - single line ultra compact layout */
        .dataTables_wrapper .row:last-child {
            display: flex !important;
            align-items: center !important;
            justify-content: flex-start !important;
            flex-wrap: nowrap !important;
            padding: 0.5rem 0 !important;
            margin: 0 !important;
            border-top: 1px solid #dee2e6;
            width: 100%;
            min-height: 32px;
        }
        .dataTables_wrapper .row:last-child > div {
            display: flex !important;
            align-items: center !important;
            flex-wrap: nowrap !important;
            gap: 1rem !important;
            flex: 1 1 auto;
            max-width: 100% !important;
            width: 100% !important;
        }
        /* Length selector */
        .dataTables_wrapper .dataTables_length {
            padding: 0 !important;
            margin: 0 !important;
            flex: 0 0 auto;
            order: 1;
        }
        /* Info text */
        .dataTables_wrapper .dataTables_info {
            padding: 0 !important;
            margin: 0 !important;
            flex: 1 1 auto;
            order: 2;
            text-align: center;
        }
        /* Pagination */
        .dataTables_wrapper .dataTables_paginate {
            padding: 0 !important;
            margin: 0 !important;
            flex: 0 0 auto;
            order: 3;
            gap: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination {
            margin: 0;
            gap: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 0.05rem 0.15rem;
            font-size: 0.65rem;
            min-width: 18px;
            height: 18px;
            line-height: 18px;
            margin: 0 !important;
            border-radius: 0.1rem;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item {
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item + .page-item .page-link {
            margin-left: -1px !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item .page-link {
            padding: 0.15rem 0.45rem !important;
            font-size: 0.8rem !important;
            line-height: 1.3 !important;
            min-width: auto !important;
            border-radius: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item:first-child .page-link {
            border-top-left-radius: 0.2rem !important;
            border-bottom-left-radius: 0.2rem !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item:last-child .page-link {
            border-top-right-radius: 0.2rem !important;
            border-bottom-right-radius: 0.2rem !important;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Initialize DataTables for appointments pagination
            if (document.getElementById('appointmentsTable')) {
                $('#appointmentsTable').DataTable({
                    serverSide: true,
                    processing: true,
                    pageLength: 10,
                    paging: true,
                    searching: false,
                    ordering: true,
                    order: [[0, 'desc']], // Default sort by date descending
                    info: true,
                    language: {
                        url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json'
                    },
                    ajax: {
                        url: '/Index?handler=Appointments',
                        type: 'GET',
                        data: function(d) {
                            // DataTables sends order info, we add it for server processing
                            return d;
                        },
                        dataSrc: 'data',
                        error: function (xhr, status, error) {
                            console.error('DataTables error:', error, xhr);
                        }
                    },
                    columns: [
                        { 
                            data: 'scheduledAt',
                            className: 'fw-semibold',
                            render: function(data) {
                                if (!data) return '-';
                                var m = moment(data);
                                return '<span title="' + m.format('DD/MM/YYYY HH:mm') + '">' + m.fromNow() + '</span>';
                            },
                            orderable: true
                        },
                        { 
                            data: null,
                            render: function(data) {
                                return '<div class="fw-semibold">' + data.patientName + '</div>' +
                                       '<div class="small text-muted">ID: ' + data.patientId + '</div>';
                            },
                            orderable: false
                        },
                        { 
                            data: null,
                            render: function(data) {
                                return '<div class="fw-semibold">' + data.staffName + '</div>' +
                                       '<div class="small text-muted">ID: ' + data.staffId + '</div>';
                            },
                            orderable: false
                        },
                        { 
                            data: 'reason',
                            orderable: true
                        },
                        { 
                            data: null,
                            render: function(data) {
                                const statusColors = {
                                    'Scheduled': 'primary',
                                    'CheckedIn': 'info',
                                    'InProgress': 'warning',
                                    'Completed': 'success',
                                    'Cancelled': 'danger',
                                    'NoShow': 'secondary'
                                };
                                const color = statusColors[data.status] || 'secondary';
                                return '<span class="badge bg-' + color + '">' + data.status + '</span>';
                            },
                            orderable: true
                        },
                        { 
                            data: null,
                            render: function(data) {
                                return '<a class="btn btn-sm btn-outline-primary" href="/Appointments/' + data.id + '">Chi tiết</a>';
                            },
                            orderable: false,
                            searchable: false
                        }
                    ],
                    dom: '<"row"<"col-sm-12"f>>rt<"row"<"col-sm-12"<"dataTables_length"l><"dataTables_info"i><"dataTables_paginate"p>>>',
                    drawCallback: function(settings) {
                        console.log('DataTables draw complete');
                    }
                });
            }
        });
    </script>
}