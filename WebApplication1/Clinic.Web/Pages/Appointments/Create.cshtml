@page
@model Clinic.Web.Pages.Appointments.CreateModel
@{
    ViewData["Title"] = "New Appointment";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Tạo lịch khám mới</h2>
    <div>
        <a class="btn btn-sm btn-outline-secondary" href="/index">Quay lại</a>
        <a class="btn btn-sm btn-primary" href="/Patients/Create" target="_blank"><i class="bi bi-plus-circle me-1"></i>Thêm bệnh nhân mới</a>
    </div>
</div>

<div class="card p-3">
    @Html.AntiForgeryToken()
    <div class="row g-3">
        <div class="col-md-6">
            <div class="d-flex align-items-center mb-1">
                <label class="form-label mb-0 me-auto">Bệnh nhân</label>
            </div>
            <div class="position-relative">
                <input type="text" id="patientSearch" class="form-control" placeholder="Nhập tên hoặc SĐT bệnh nhân..." autocomplete="off" />
                <input type="hidden" id="patientId" />
                <div id="patientDropdown" class="dropdown-menu w-100" style="max-height:250px;overflow-y:auto;"></div>
            </div>
            <div id="patientInfo" class="small text-muted mt-1" style="display:none;"></div>
        </div>

        <div class="col-md-3">
            <label class="form-label">Chọn ngày khám</label>
            <input type="date" id="date" class="form-control" />
        </div>

        <div class="col-md-3">
            <label class="form-label">Chọn bác sĩ</label>
            <select id="doctorSelect" class="form-select">
                <option value="">Đang tải...</option>
            </select>
        </div>

        <div class="col-md-6">
            <label class="form-label">Lý do khám</label>
            <input type="text" id="reason" class="form-control" placeholder="VD: Khám tổng quát, tái khám..." />
        </div>

        <div class="col-12">
            <label class="form-label">Chọn ca khám (30 phút 1 ca)</label>
            <div id="slots" class="d-flex flex-wrap gap-2">
                <div class="text-muted">Chọn ngày và bác sĩ để thấy các ca khả dụng.</div>
            </div>
        </div>

        <div class="col-12 text-end">
            <button type="button" class="btn btn-primary" id="submitBtn" disabled>
                Đặt lịch
            </button>
        </div>
    </div>
</div>

@section Scripts {
<style>
    .slot-btn { min-width: 120px; }
    .slot-btn.btn-busy { opacity: 0.5; text-decoration: line-through; }
</style>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const patientSearch = document.getElementById('patientSearch');
    const patientIdInput = document.getElementById('patientId');
    const patientDropdown = document.getElementById('patientDropdown');
    const patientInfo = document.getElementById('patientInfo');
    const dateInput = document.getElementById('date');
    const doctorSelect = document.getElementById('doctorSelect');
    const slotsContainer = document.getElementById('slots');
    const reasonInput = document.getElementById('reason');
    const submitBtn = document.getElementById('submitBtn');

    let selectedSlotTime = null;
    let searchTimeout = null;

    // Set default date to today
    dateInput.value = new Date().toISOString().split('T')[0];

    // ===== LOAD DOCTORS =====
    async function loadDoctors() {
        try {
            const res = await fetch('/Appointments/Create?handler=StaffList');
            const data = await res.json();
            doctorSelect.innerHTML = '<option value="">-- Chọn bác sĩ --</option>';
            data.forEach(function(s) {
                const opt = document.createElement('option');
                opt.value = s.id;
                opt.textContent = s.fullName;
                doctorSelect.appendChild(opt);
            });
        } catch (err) {
            console.error('Error loading staff:', err);
            doctorSelect.innerHTML = '<option value="">Lỗi tải danh sách</option>';
        }
    }
    loadDoctors();

    // ===== PATIENT SEARCH (AUTOCOMPLETE) =====
    patientSearch.addEventListener('input', function () {
        // Clear patient selection when user actually edits the text
        if (patientIdInput.value) {
            patientIdInput.value = '';
            patientInfo.style.display = 'none';
            updateSubmitBtn();
        }

        clearTimeout(searchTimeout);
        const term = this.value.trim();
        if (term.length < 2) {
            patientDropdown.classList.remove('show');
            return;
        }
        searchTimeout = setTimeout(async function () {
            try {
                const res = await fetch('/Appointments/Create?handler=SearchPatients&term=' + encodeURIComponent(term));
                const data = await res.json();
                patientDropdown.innerHTML = '';
                if (data.length === 0) {
                    patientDropdown.innerHTML = '<div class="dropdown-item text-muted">Không tìm thấy</div>' +
                        '<a class="dropdown-item text-primary fw-semibold" href="/Patients/Create" target="_blank"><i class="bi bi-plus-circle me-1"></i>Thêm bệnh nhân mới</a>';
                } else {
                    data.forEach(function (p) {
                        const item = document.createElement('a');
                        item.className = 'dropdown-item';
                        item.href = 'javascript:void(0)';
                        item.innerHTML = '<div class="fw-semibold">' + p.fullName + '</div><div class="small text-muted">ID: ' + p.id + (p.phone ? ' · ' + p.phone : '') + ' · ' + p.dateOfBirth + '</div>';
                        item.addEventListener('click', function () {
                            patientIdInput.value = p.id;
                            patientSearch.value = p.fullName;
                            patientInfo.textContent = 'ID: ' + p.id + (p.phone ? ' · SĐT: ' + p.phone : '') + ' · Ngày sinh: ' + p.dateOfBirth;
                            patientInfo.style.display = '';
                            patientDropdown.classList.remove('show');
                            updateSubmitBtn();
                        });
                        patientDropdown.appendChild(item);
                    });
                }
                patientDropdown.classList.add('show');
            } catch (err) {
                console.error('Error searching patients:', err);
            }
        }, 300);
    });

    // Close dropdown on outside click
    document.addEventListener('click', function (e) {
        if (!patientSearch.contains(e.target) && !patientDropdown.contains(e.target)) {
            patientDropdown.classList.remove('show');
        }
    });

    // ===== LOAD AVAILABLE SLOTS =====
    async function loadSlots() {
        const date = dateInput.value;
        const staffId = doctorSelect.value;
        selectedSlotTime = null;
        updateSubmitBtn();

        if (!date || !staffId) {
            slotsContainer.innerHTML = '<div class="text-muted">Chọn ngày và bác sĩ để thấy các ca khả dụng.</div>';
            return;
        }

        slotsContainer.innerHTML = '<div class="spinner-border spinner-border-sm text-primary" role="status"></div> <span class="text-muted">Đang tải ca khám...</span>';

        try {
            const res = await fetch('/Appointments/Create?handler=Availability&staffId=' + staffId + '&date=' + date);
            if (!res.ok) {
                slotsContainer.innerHTML = '<div class="text-danger">Lỗi tải ca khám.</div>';
                return;
            }
            const data = await res.json();
            slotsContainer.innerHTML = '';

            var bookedTimes = (data.bookedSlots || []).map(function(s) { return s.start; });

            if (data.availableSlots.length === 0 && bookedTimes.length === 0) {
                slotsContainer.innerHTML = '<div class="text-muted">Không có ca làm việc cho ngày này.</div>';
                return;
            }

            // Show all slots (available + booked)
            var allSlots = [];
            data.availableSlots.forEach(function(s) { allSlots.push({ start: s.start, end: s.end, booked: false }); });
            data.bookedSlots.forEach(function(s) { allSlots.push({ start: s.start, end: s.end, booked: true }); });
            allSlots.sort(function(a, b) { return a.start.localeCompare(b.start); });

            allSlots.forEach(function(slot) {
                var btn = document.createElement('button');
                btn.type = 'button';
                btn.className = 'btn btn-outline-secondary slot-btn';
                btn.textContent = slot.start + ' → ' + slot.end;
                btn.dataset.time = slot.start;

                if (slot.booked) {
                    btn.disabled = true;
                    btn.classList.add('btn-busy');
                    // Tìm thông tin bệnh nhân cho slot này
                    var info = (data.bookedSlots || []).find(function(s) { return s.start === slot.start; });
                    var tooltipText = 'Đã được đặt';
                    if (info && info.patientName) {
                        tooltipText = 'Bác sĩ đã có lịch với: ' + info.patientName + (info.patientId ? ' (ID: ' + info.patientId + ')' : '') + (info.reason ? '\nLý do: ' + info.reason : '');
                    }
                    var wrapper = document.createElement('span');
                    wrapper.setAttribute('data-bs-toggle', 'tooltip');
                    wrapper.setAttribute('data-bs-title', tooltipText);
                    wrapper.appendChild(btn);
                    slotsContainer.appendChild(wrapper);
                } else {
                    btn.addEventListener('click', function () {
                        slotsContainer.querySelectorAll('.slot-btn.active').forEach(function(el) {
                            el.classList.remove('active', 'btn-primary');
                            el.classList.add('btn-outline-secondary');
                        });
                        btn.classList.add('active', 'btn-primary');
                        btn.classList.remove('btn-outline-secondary');
                        selectedSlotTime = slot.start;
                        updateSubmitBtn();
                    });
                    slotsContainer.appendChild(btn);
                }
            });

            // Khởi tạo lại tooltip cho tất cả slot đã book (span có data-bs-toggle="tooltip")
            var tooltipTriggerList = [].slice.call(slotsContainer.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.forEach(function (el) {
                new bootstrap.Tooltip(el);
            });

            if (allSlots.filter(function(s) { return !s.booked; }).length === 0) {
                slotsContainer.insertAdjacentHTML('beforeend', '<div class="text-warning mt-2 w-100">Tất cả ca đã được đặt hết.</div>');
            }
        } catch (err) {
            console.error('Error loading slots:', err);
            slotsContainer.innerHTML = '<div class="text-danger">Lỗi tải ca khám.</div>';
        }
    }

    dateInput.addEventListener('change', loadSlots);
    doctorSelect.addEventListener('change', loadSlots);

    // ===== SUBMIT =====
    function updateSubmitBtn() {
        submitBtn.disabled = !(patientIdInput.value && dateInput.value && doctorSelect.value && selectedSlotTime);
    }

    submitBtn.addEventListener('click', async function () {
        var pid = patientIdInput.value;
        var staffId = doctorSelect.value;
        var date = dateInput.value;
        var reason = reasonInput.value.trim();

        if (!pid || !staffId || !date || !selectedSlotTime) {
            toastr.warning('Vui lòng điền đầy đủ thông tin.');
            return;
        }

        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Đang xử lý...';

        try {
            var token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            var formData = new URLSearchParams();
            formData.append('patientId', pid);
            formData.append('staffId', staffId);
            formData.append('date', date);
            formData.append('time', selectedSlotTime);
            formData.append('reason', reason);

            var res = await fetch('/Appointments/Create', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token
                },
                body: formData.toString()
            });

            var json = await res.json();

            if (!res.ok || !json.success) {
                toastr.error(json.error || 'Lỗi khi tạo lịch hẹn.');
                submitBtn.disabled = false;
                submitBtn.innerHTML = 'Đặt lịch';
                return;
            }

            toastr.success('Đặt lịch thành công!');
            setTimeout(function() { window.location.href = '/'; }, 1500);
        } catch (err) {
            console.error('Error creating appointment:', err);
            toastr.error('Lỗi khi tạo lịch hẹn.');
            submitBtn.disabled = false;
            submitBtn.innerHTML = 'Đặt lịch';
        }
    });
});
</script>
}
