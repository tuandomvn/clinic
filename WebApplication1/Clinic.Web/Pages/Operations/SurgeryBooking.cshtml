@page
@model Clinic.Web.Pages.Operations.SurgeryBookingModel
@{
    ViewData["Title"] = "Đặt lịch mổ";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Đặt lịch mổ</h2>
    <div>
        <a class="btn btn-sm btn-outline-secondary" href="/Appointments">Quay lại</a>
        <a class="btn btn-sm btn-primary" href="/Patients/Create" target="_blank"><i class="bi bi-plus-circle me-1"></i>Thêm bệnh nhân mới</a>
    </div>
</div>

<div class="card p-3">
    <form id="surgeryForm">
        <div class="row g-3">
            <div class="col-md-6">
                <div class="d-flex align-items-center mb-1">
                    <label class="form-label mb-0 me-auto">Bệnh nhân</label>
                </div>
                <div class="position-relative">
                    <input type="text" id="patient" class="form-control" placeholder="Nhập tên hoặc SĐT bệnh nhân..." autocomplete="off" />
                    <input type="hidden" id="patientId" />
                    <div id="patientDropdown" class="dropdown-menu w-100" style="max-height:250px;overflow-y:auto;"></div>
                </div>
                <div id="patientInfo" class="small text-muted mt-1" style="display:none;"></div>
            </div>

            <div class="col-md-3">
                <label class="form-label">Chọn ngày mổ</label>
                <input type="date" id="date" class="form-control" />
            </div>

            <div class="col-md-3">
                <label class="form-label">Chọn phòng mổ</label>
                <select id="room" class="form-select">
                    <option value="">Chọn phòng</option>
                </select>
            </div>

            <div class="col-12">
                <label class="form-label">Chọn đội ngũ (bác sĩ & điều dưỡng)</label>
                <div id="staffList" class="d-flex flex-wrap gap-2">
                    <div class="text-muted">Chọn ngày mổ.</div>
                </div>
            </div>

            <div class="col-12">
                <label class="form-label">Ca khả dụng</label>
                <div id="groupSlots" class="d-flex flex-wrap gap-2">
                    <div class="text-muted">Chọn ngày, phòng và ít nhất 1 thành viên để thấy ca khả dụng.</div>
                </div>
            </div>

            <div class="col-12 text-end">
                <button type="button" class="btn btn-primary" id="submitSurgery">Đặt lịch mổ</button>
            </div>
        </div>
    </form>
</div>

<script>
    // Staff loaded from database
    let staffInfo = {};

    // Rooms loaded from database
    let roomsInfo = {};

    // Shift definitions per entity - default working hours for staff (until shift management is implemented)
    const staffDefaultShifts = [ { start: '07:30', end: '12:00' }, { start: '13:00', end: '17:00' } ];

    // Default operating hours for rooms (all rooms share the same window)
    const roomDefaultShifts = [ { start: '07:00', end: '18:00' } ];

    // staff booked cache from DB
    const staffBookedCache = {};
    // room booked cache from DB
    const roomBookedCache = {};

    function pad(n) { return n.toString().padStart(2, '0'); }
    function timeToMinutes(t) { const [hh, mm] = t.split(':').map(Number); return hh*60 + mm; }
    function minutesToTime(m) { const hh = Math.floor(m/60); const mm = m%60; return pad(hh)+':'+pad(mm); }

    function generateSlotsForShift(shift, duration=30) {
        const start = timeToMinutes(shift.start);
        const end = timeToMinutes(shift.end);
        const slots = [];
        for (let t = start; t + duration <= end; t += duration) {
            slots.push({ from: minutesToTime(t), to: minutesToTime(t + duration) });
        }
        return slots;
    }

    function allSlotsForEntity(entityId, duration=30) {
        // If entityId is a room (exists in roomsInfo), use default room shifts; otherwise staff shifts
        const isRoom = roomsInfo[entityId] !== undefined;
        const shifts = isRoom ? roomDefaultShifts : staffDefaultShifts;
        let slots = [];
        shifts.forEach(s => { slots = slots.concat(generateSlotsForShift(s, duration)); });
        return slots;
    }

    // Load booked surgeries for a room from DB
    async function getRoomBooked(date, roomId) {
        const key = date + '::room::' + roomId;
        if (roomBookedCache[key]) return roomBookedCache[key];
        try {
            const res = await fetch('/Operations/SurgeryBooking?handler=RoomSurgeries&roomId=' + roomId + '&date=' + encodeURIComponent(date));
            const data = await res.json();
            const bookedStarts = data.map(a => a.from);
            roomBookedCache[key] = bookedStarts;
            return bookedStarts;
        } catch(err) {
            console.error('Error loading room appointments:', err);
            return [];
        }
    }

    // Load booked surgeries for a staff member from DB
    async function getStaffBooked(date, staffId) {
        const key = date + '::staff::' + staffId;
        if (staffBookedCache[key]) return staffBookedCache[key];
        try {
            const res = await fetch('/Operations/SurgeryBooking?handler=StaffSurgeries&staffId=' + staffId + '&date=' + encodeURIComponent(date));
            const data = await res.json();
            const bookedStarts = data.map(a => a.from);
            staffBookedCache[key] = bookedStarts;
            return bookedStarts;
        } catch(err) {
            console.error('Error loading staff surgeries:', err);
            return [];
        }
    }

    // compute intersection of available starts across entities
    function intersectSlotStarts(lists) {
        if (lists.length === 0) return [];
        // each list is array of strings 'HH:MM'
        const counts = {};
        lists.forEach(list => { list.forEach(t => { counts[t] = (counts[t]||0) + 1; }); });
        return Object.keys(counts).filter(t => counts[t] === lists.length).sort();
    }

    // render room options from database
    async function populateRooms() {
        try {
            const res = await fetch('/Operations/SurgeryBooking?handler=OperatingRooms');
            const data = await res.json();
            roomsInfo = {};
            data.forEach(r => { roomsInfo[r.id] = { name: r.name, location: r.location }; });
            const sel = document.getElementById('room');
            sel.innerHTML = '<option value="">Chọn phòng</option>';
            data.forEach(r => {
                const opt = document.createElement('option');
                opt.value = r.id;
                opt.innerText = r.name + (r.location ? ' (' + r.location + ')' : '');
                sel.appendChild(opt);
            });
        } catch(err) {
            console.error('Error loading rooms:', err);
        }
    }

    // Load staff from database
    async function populateStaff() {
        try {
            const res = await fetch('/Operations/SurgeryBooking?handler=Staff');
            const data = await res.json();
            staffInfo = {};
            data.forEach(s => { staffInfo[s.id] = { name: s.fullName, role: s.role }; });
        } catch(err) {
            console.error('Error loading staff:', err);
        }
    }

    function renderStaffForDate(date) {
        const container = document.getElementById('staffList');
        container.innerHTML = '';
        if (!date) { container.innerHTML = '<div class="text-muted">Chọn ngày để xem nhân sự.</div>'; return; }
        Object.keys(staffInfo).forEach(id => {
            const slotCount = allSlotsForEntity(id).length;
            const div = document.createElement('div'); div.className = 'form-check me-2';
            const input = document.createElement('input'); input.className = 'form-check-input'; input.type = 'checkbox'; input.id = 'staff-'+id; input.dataset.id = id;
            const label = document.createElement('label'); label.className = 'form-check-label ms-1'; label.htmlFor = 'staff-'+id; label.innerText = staffInfo[id].name + ' (' + staffInfo[id].role + ')';
            div.appendChild(input); div.appendChild(label); container.appendChild(div);

            input.addEventListener('change', renderGroupSlots);
        });
    }

    async function renderGroupSlots() {
        const date = document.getElementById('date').value;
        const roomId = document.getElementById('room').value;
        const checked = Array.from(document.querySelectorAll('#staffList input[type=checkbox]:checked')).map(i=>i.dataset.id);
        const out = document.getElementById('groupSlots'); out.innerHTML = '';
        if (!date || !roomId || checked.length === 0) {
            out.innerHTML = '<div class="text-muted">Chọn ngày, phòng và ít nhất 1 nhân sự để xem ca khả dụng.</div>';
            return;
        }
        // show columns per entity (room first, then each staff) so user can inspect availability
        const duration = 30;
        const entities = [roomId].concat(checked);

        // Pre-load room booked data from DB
        const roomBooked = await getRoomBooked(date, roomId);

        // Pre-load all staff booked data from DB in parallel
        const staffBookedMap = {};
        await Promise.all(checked.map(async (sid) => {
            staffBookedMap[sid] = await getStaffBooked(date, sid);
        }));

        entities.forEach(ent => {
            const col = document.createElement('div');
            col.className = 'slot-column';
            col.style.minWidth = '220px';
            col.style.flex = '0 0 220px';
            const isRoom = ent === roomId;
            const title = isRoom ? (roomsInfo[ent].name + ' (Phòng)') : (staffInfo[ent].name + ' (' + staffInfo[ent].role + ')');
            col.innerHTML = '<div class="fw-semibold mb-2">' + title + '</div>';

            const all = allSlotsForEntity(ent, duration);
            const booked = isRoom ? roomBooked : (staffBookedMap[ent] || []);

            if (!all || all.length === 0) {
                const note = document.createElement('div'); note.className = 'text-muted'; note.innerText = 'No shifts'; col.appendChild(note);
            } else {
                all.forEach(slot => {
                    const btn = document.createElement('button'); btn.type='button'; btn.className='btn btn-outline-secondary slot-btn mb-2';
                    btn.dataset.entity = ent; btn.dataset.from = slot.from; btn.dataset.to = slot.to;
                    btn.innerText = slot.from + ' → ' + slot.to;
                    if (booked.includes(slot.from)) {
                        btn.disabled = true; btn.classList.add('btn-busy'); btn.title = 'Đã được đặt (busy)';
                    } else {
                        btn.addEventListener('click', function(){
                            // toggle active per entity column (user can pick per-entity)
                            btn.classList.toggle('active');
                            if (btn.classList.contains('active')) { btn.classList.remove('btn-outline-secondary'); btn.classList.add('btn-primary'); }
                            else { btn.classList.remove('btn-primary'); btn.classList.add('btn-outline-secondary'); }
                        });
                    }
                    col.appendChild(btn);
                });
            }

            out.appendChild(col);
        });
    }

    document.getElementById('date').addEventListener('change', function(){
        const date = this.value; selectedStaff = null; renderStaffForDate(date); document.getElementById('groupSlots').innerHTML = '<div class="text-muted">Chọn ngày, phòng và ít nhất 1 nhân sự để xem ca khả dụng.</div>';
    });

    document.getElementById('room').addEventListener('change', renderGroupSlots);

    document.getElementById('submitSurgery').addEventListener('click', async function(){
        const patient = document.getElementById('patient').value.trim();
        const patientIdVal = document.getElementById('patientId').value;
        const date = document.getElementById('date').value;
        const room = document.getElementById('room').value;
        const staff = Array.from(document.querySelectorAll('#staffList input[type=checkbox]:checked')).map(i=>i.dataset.id);
        const roomSelected = document.querySelector('#groupSlots .slot-column:first-child .slot-btn.active');
        if (!patient || !patientIdVal) { toastr.warning('Vui lòng chọn bệnh nhân.'); return; }
        if (!date) { toastr.warning('Vui lòng chọn ngày.'); return; }
        if (!room) { toastr.warning('Vui lòng chọn phòng mổ.'); return; }
        if (staff.length === 0) { toastr.warning('Vui lòng chọn ít nhất 1 bác sĩ hoặc điều dưỡng.'); return; }
        if (!roomSelected) { toastr.warning('Vui lòng chọn ca mổ cho phòng.'); return; }

        // Collect per-staff selected slots
        const staffFroms = [];
        const staffTos = [];
        const columns = document.querySelectorAll('#groupSlots .slot-column');
        let missingStaff = false;
        for (let i = 0; i < staff.length; i++) {
            // Staff columns start after the room column (index 0)
            const staffCol = columns[i + 1];
            const staffSlot = staffCol ? staffCol.querySelector('.slot-btn.active') : null;
            if (!staffSlot) {
                const staffName = staffInfo[staff[i]]?.name || staff[i];
                toastr.warning('Vui lòng chọn ca cho ' + staffName + '.');
                missingStaff = true;
                break;
            }
            staffFroms.push(staffSlot.dataset.from);
            staffTos.push(staffSlot.dataset.to);
        }
        if (missingStaff) return;

        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
        const params = new URLSearchParams();
        params.append('patientId', patientIdVal);
        params.append('roomId', room);
        params.append('date', date);
        params.append('timeFrom', roomSelected.dataset.from);
        params.append('timeTo', roomSelected.dataset.to);
        params.append('reason', 'Phẫu thuật');
        staff.forEach(s => params.append('staffIds', s));
        staffFroms.forEach(f => params.append('staffFroms', f));
        staffTos.forEach(t => params.append('staffTos', t));

        try {
            const res = await fetch('/Operations/SurgeryBooking?handler=BookSurgery', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': token || ''
                },
                body: params.toString()
            });
            const result = await res.json();
            if (result.success) {
                toastr.success('Đặt mổ thành công!\nBệnh nhân: ' + patient + '\nNgày: ' + date + '\nPhòng: ' + roomsInfo[room].name + '\nĐội ngũ: ' + staff.map(s=>staffInfo[s].name).join(', '));
                // Clear caches and refresh slots
                Object.keys(roomBookedCache).forEach(k => { if (k.includes('::room::' + room)) delete roomBookedCache[k]; });
                staff.forEach(s => { Object.keys(staffBookedCache).forEach(k => { if (k.includes('::staff::' + s)) delete staffBookedCache[k]; }); });
                renderGroupSlots();
            } else {
                toastr.error(result.message || 'Đặt lịch mổ thất bại.');
            }
        } catch(err) {
            console.error('Error booking surgery:', err);
            toastr.error('Lỗi kết nối. Vui lòng thử lại.');
        }
    });

    // ===== PATIENT SEARCH (AUTOCOMPLETE) =====
    (function() {
        const patientSearch = document.getElementById('patient');
        const patientIdInput = document.getElementById('patientId');
        const patientDropdown = document.getElementById('patientDropdown');
        const patientInfoEl = document.getElementById('patientInfo');
        let searchTimeout = null;

        patientSearch.addEventListener('input', function() {
            if (patientIdInput.value) {
                patientIdInput.value = '';
                patientInfoEl.style.display = 'none';
            }
            clearTimeout(searchTimeout);
            const term = this.value.trim();
            if (term.length < 2) {
                patientDropdown.classList.remove('show');
                return;
            }
            searchTimeout = setTimeout(async function() {
                try {
                    const res = await fetch('/Operations/SurgeryBooking?handler=SearchPatients&term=' + encodeURIComponent(term));
                    const data = await res.json();
                    patientDropdown.innerHTML = '';
                    if (data.length === 0) {
                        patientDropdown.innerHTML = '<div class="dropdown-item text-muted">Không tìm thấy</div>' +
                            '<a class="dropdown-item text-primary fw-semibold" href="/Patients/Create" target="_blank"><i class="bi bi-plus-circle me-1"></i>Thêm bệnh nhân mới</a>';
                    } else {
                        data.forEach(function(p) {
                            const item = document.createElement('a');
                            item.className = 'dropdown-item';
                            item.href = 'javascript:void(0)';
                            item.innerHTML = '<div class="fw-semibold">' + p.fullName + '</div><div class="small text-muted">ID: ' + p.id + (p.phone ? ' \u00b7 ' + p.phone : '') + ' \u00b7 ' + p.dateOfBirth + '</div>';
                            item.addEventListener('click', function() {
                                patientIdInput.value = p.id;
                                patientSearch.value = p.fullName;
                                patientInfoEl.textContent = 'ID: ' + p.id + (p.phone ? ' \u00b7 S\u0110T: ' + p.phone : '') + ' \u00b7 Ng\u00e0y sinh: ' + p.dateOfBirth;
                                patientInfoEl.style.display = '';
                                patientDropdown.classList.remove('show');
                            });
                            patientDropdown.appendChild(item);
                        });
                    }
                    patientDropdown.classList.add('show');
                } catch(err) {
                    console.error('Error searching patients:', err);
                }
            }, 300);
        });

        document.addEventListener('click', function(e) {
            if (!patientSearch.contains(e.target) && !patientDropdown.contains(e.target)) {
                patientDropdown.classList.remove('show');
            }
        });
    })();

    // initial populate rooms and staff from DB
    populateRooms();
    populateStaff();
</script>
