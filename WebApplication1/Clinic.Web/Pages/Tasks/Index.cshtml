@page
@model Clinic.Web.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "Reminder Tasks";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Reminder Tasks</h2>
        <div class="text-muted small">Danh sách nhắc nhở theo dõi bệnh nhân</div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <div class="btn-group me-2" role="group" aria-label="Chọn tuần">
            <button type="button" data-week="0" class="btn btn-sm btn-outline-secondary week-btn active">Hôm nay</button>
            <button type="button" data-week="1" class="btn btn-sm btn-outline-secondary week-btn">Tuần này</button>
            <button type="button" data-week="2" class="btn btn-sm btn-outline-secondary week-btn">Tuần kế tiếp</button>
            <button type="button" data-week="3" class="btn btn-sm btn-outline-secondary week-btn">2 tuần kế tiếp</button>
        </div>
        <span class="badge bg-danger rounded-pill" id="todayBadge">@Model.TodayPendingCount việc cần làm hôm nay</span>
        <a class="btn btn-sm btn-primary" href="/Tasks/Create"><i class="bi bi-plus-circle me-1"></i>Tạo task mới</a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-3 p-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-3">
            <input id="taskSearch" class="form-control form-control-sm" placeholder="Tìm theo tên bệnh nhân, SĐT..." />
        </div>
        <div class="col-md-2">
            <select class="form-select form-select-sm" id="filterType">
                <option value="">Tất cả loại</option>
                <option value="FollowUp">Follow-up sau mổ</option>
                <option value="BirthdayGreeting">Chúc mừng sinh nhật</option>
                <option value="VaccinationReminder">Nhắc lịch tiêm chủng</option>
                <option value="PeriodicTest">Xét nghiệm định kỳ</option>
                <option value="General">Khác</option>
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select form-select-sm" id="filterStatus">
                <option value="">Tất cả</option>
                <option value="pending" selected>Chưa xong</option>
                <option value="done">Đã xong</option>
            </select>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<!-- Task Table -->
<div class="card p-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <button class="btn btn-sm btn-primary" id="btnMarkDone" disabled>
                <i class="bi bi-check2-square"></i> Đã hoàn thành
            </button>
            <button class="btn btn-sm btn-outline-success" id="btnMarkUndone" disabled>
                <i class="bi bi-arrow-counterclockwise"></i> Chưa hoàn thành
            </button>
            <span class="small text-muted ms-2" id="selectedCount"></span>
        </div>
    </div>
    <div class="table-responsive">
        <table id="taskTable" class="table table-hover align-middle mb-0" style="width:100%">
            <thead class="table-light">
                <tr>
                    <th data-orderable="false" style="width:36px;">
                        <input class="form-check-input" type="checkbox" id="checkAll" title="Chọn tất cả" />
                    </th>
                    <th>Bệnh nhân</th>
                    <th>Loại</th>
                    <th>Mô tả</th>
                    <th>Ngày hẹn</th>
                    <th data-orderable="false">Trạng thái</th>
                    <th data-orderable="false">Hoàn thành bởi</th>
                    <th data-orderable="false" style="width:60px;"></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/moment@2.30.1/min/moment-with-locales.min.js"></script>
    <script>moment.locale('vi');</script>
    <style>
        #taskTable {
            font-size: 0.85rem;
        }
        #taskTable thead th {
            font-size: 0.8rem;
            font-weight: 600;
            padding: 0.5rem 0.75rem;
            border-bottom: 2px solid #dee2e6;
            user-select: none;
        }
        #taskTable thead th:hover {
            background-color: #e9ecef;
        }
        #taskTable tbody td {
            padding: 0.4rem 0.75rem;
            vertical-align: middle;
        }
        #taskTable tbody tr:hover {
            background-color: #f8f9fa !important;
        }
        .bg-pink {
            background-color: #e91e8c;
            color: #fff;
        }
        .task-checkbox {
            width: 1.1rem;
            height: 1.1rem;
            cursor: pointer;
        }
        .task-checkbox:checked {
            background-color: #198754;
            border-color: #198754;
        }
        #checkAll {
            width: 1.1rem;
            height: 1.1rem;
            cursor: pointer;
        }
        .dataTables_info {
            font-size: 0.8rem;
            white-space: nowrap;
        }
        .dataTables_wrapper .dataTables_paginate {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 0 !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination {
            margin: 0;
            gap: 0 !important;
        }
        .dataTables_wrapper .dataTables_length {
            font-size: 0.8rem;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_length label {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            margin: 0;
            white-space: nowrap;
            font-size: 0.8rem;
        }
        .dataTables_wrapper .dataTables_length select {
            padding: 0.2rem 1.5rem 0.2rem 0.4rem;
            font-size: 0.8rem;
            border: 1px solid #dee2e6;
            border-radius: 0.2rem;
            height: 28px;
            width: 60px;
        }
        .dataTables_wrapper {
            position: relative;
        }
        .dataTables_wrapper .row:last-child {
            display: flex !important;
            align-items: center !important;
            justify-content: flex-start !important;
            flex-wrap: nowrap !important;
            padding: 0.5rem 0 !important;
            margin: 0 !important;
            border-top: 1px solid #dee2e6;
            width: 100%;
            min-height: 32px;
        }
        .dataTables_wrapper .row:last-child > div {
            display: flex !important;
            align-items: center !important;
            flex-wrap: nowrap !important;
            gap: 1rem !important;
            flex: 1 1 auto;
            max-width: 100% !important;
            width: 100% !important;
        }
        .dataTables_wrapper .dataTables_length {
            padding: 0 !important;
            margin: 0 !important;
            flex: 0 0 auto;
            order: 1;
        }
        .dataTables_wrapper .dataTables_info {
            padding: 0 !important;
            margin: 0 !important;
            flex: 1 1 auto;
            order: 2;
            text-align: center;
        }
        .dataTables_wrapper .dataTables_paginate {
            padding: 0 !important;
            margin: 0 !important;
            flex: 0 0 auto;
            order: 3;
            gap: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination {
            margin: 0;
            gap: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 0.05rem 0.15rem;
            font-size: 0.65rem;
            min-width: 18px;
            height: 18px;
            line-height: 18px;
            margin: 0 !important;
            border-radius: 0.1rem;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item {
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item + .page-item .page-link {
            margin-left: -1px !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item .page-link {
            padding: 0.15rem 0.45rem !important;
            font-size: 0.8rem !important;
            line-height: 1.3 !important;
            min-width: auto !important;
            border-radius: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item:first-child .page-link {
            border-top-left-radius: 0.2rem !important;
            border-bottom-left-radius: 0.2rem !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item:last-child .page-link {
            border-top-right-radius: 0.2rem !important;
            border-bottom-right-radius: 0.2rem !important;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // ===== TUẦN FILTER =====
            function getWeekRange(offset) {
                var today = new Date();
                today.setHours(0,0,0,0);
                if (offset === 0) {
                    var ds = today.toISOString().split('T')[0];
                    return { from: ds, to: ds };
                }
                var day = today.getDay();
                var diffToMon = (day === 0 ? -6 : 1 - day);
                var monday = new Date(today);
                monday.setDate(today.getDate() + diffToMon + 7 * (offset - 1));
                var sunday = new Date(monday);
                sunday.setDate(monday.getDate() + 6);
                return { from: monday.toISOString().split('T')[0], to: sunday.toISOString().split('T')[0] };
            }
            window.taskFilterDateFrom = null;
            window.taskFilterDateTo = null;
            var activeWeekOffset = 0;
            document.querySelectorAll('.week-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.week-btn').forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    activeWeekOffset = parseInt(btn.dataset.week);
                    var range = getWeekRange(activeWeekOffset);
                    window.taskFilterDateFrom = range.from;
                    window.taskFilterDateTo = range.to;
                    table.ajax.reload();
                });
            });
            var typeBadgeClass = {
                'FollowUp': 'bg-info text-dark',
                'BirthdayGreeting': 'bg-pink',
                'VaccinationReminder': 'bg-success',
                'PeriodicTest': 'bg-primary',
                'General': 'bg-secondary'
            };

            var table = $('#taskTable').DataTable({
                serverSide: true,
                processing: true,
                pageLength: 10,
                paging: true,
                searching: false,
                ordering: true,
                order: [[4, 'asc']],
                info: true,
                language: {
                    url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json'
                },
                ajax: {
                    url: '/Tasks?handler=TaskList',
                    type: 'GET',
                    data: function (d) {
                        d.search = document.getElementById('taskSearch').value;
                        d.filterType = document.getElementById('filterType').value;
                        d.filterStatus = document.getElementById('filterStatus').value;
                        if (window.taskFilterDateFrom) d.filterDateFrom = window.taskFilterDateFrom;
                        if (window.taskFilterDateTo) d.filterDateTo = window.taskFilterDateTo;
                        return d;
                    },
                    dataSrc: 'data',
                    error: function (xhr, status, error) {
                        console.error('DataTables error:', error, xhr);
                    }
                },
                columns: [
                    {
                        data: null,
                        render: function (d) {
                            return '<input class="form-check-input task-checkbox" type="checkbox" value="' + d.id + '" data-done="' + d.isDone + '" />';
                        },
                        orderable: false,
                        searchable: false,
                        className: 'text-center'
                    },
                    {
                        data: null,
                        render: function (d) {
                            var cls = d.isDone ? 'text-decoration-line-through text-muted' : '';
                            return '<div class="' + cls + '">' +
                                       '<div class="fw-semibold">' + d.patientName + '</div>' +
                                       '<div class="small text-muted">' + d.patientPhone + '</div>' +
                                   '</div>';
                        },
                        orderable: true
                    },
                    {
                        data: null,
                        render: function (d) {
                            var badge = typeBadgeClass[d.taskType] || 'bg-secondary';
                            return '<span class="badge ' + badge + '" style="font-size:0.7rem;">' + d.taskTypeDisplay + '</span>';
                        },
                        orderable: true
                    },
                    {
                        data: null,
                        render: function (d) {
                            var cls = d.isDone ? 'text-decoration-line-through text-muted' : '';
                            return '<span class="' + cls + '" style="font-size:0.85rem;">' + d.description + '</span>';
                        },
                        orderable: false
                    },
                    {
                        data: null,
                        render: function (d) {
                            var dateStr = d.dueDate;
                            var parts = dateStr.split('/');
                            var isoDate = parts[2] + '-' + parts[1] + '-' + parts[0];
                            var m = moment(isoDate, 'YYYY-MM-DD');
                            var relative = m.isValid() ? m.fromNow() : '';
                            if (d.isDone) {
                                return '<div class="text-decoration-line-through text-muted">' + dateStr + '</div><small class="text-muted">' + relative + '</small>';
                            }
                            if (d.isOverdue) {
                                return '<div class="text-danger fw-semibold">' + dateStr + '</div><small class="text-muted">' + relative + '</small>';
                            }
                            return '<div>' + dateStr + '</div><small class="text-muted">' + relative + '</small>';
                        },
                        orderable: true
                    },
                    {
                        data: null,
                        render: function (d) {
                            if (d.isDone) return '<span class="badge bg-success" style="font-size:0.65rem;">Đã xong</span>';
                            return '<span class="badge bg-outline-warning text-warning border border-warning" style="font-size:0.65rem;">Chưa xong</span>';
                        },
                        orderable: false
                    },
                    {
                        data: null,
                        render: function (d) {
                            return '<span class="small text-muted">' + d.doneBy + '</span>';
                        },
                        orderable: false
                    },
                    {
                        data: null,
                        render: function (d) {
                            return '<a class="btn btn-sm btn-outline-primary" href="" style="font-size:0.7rem;padding:0.15rem 0.3rem;">Xem</a>';
                        },
                        orderable: false,
                        searchable: false
                    }
                ],
                dom: '<"row"<"col-sm-12"f>>rt<"row"<"col-sm-12"<"dataTables_length"l><"dataTables_info"i><"dataTables_paginate"p>>>',
                drawCallback: function () {
                    // Uncheck header checkbox on redraw
                    $('#checkAll').prop('checked', false);
                    updateSelectedCount();
                }
            });

            // Select all checkbox
            $('#checkAll').on('change', function () {
                var checked = this.checked;
                $('#taskTable tbody .task-checkbox').prop('checked', checked);
                updateSelectedCount();
            });

            // Individual checkbox change
            $('#taskTable').on('change', '.task-checkbox', function () {
                var allChecked = $('#taskTable tbody .task-checkbox').length === $('#taskTable tbody .task-checkbox:checked').length;
                $('#checkAll').prop('checked', allChecked);
                updateSelectedCount();
            });

            function updateSelectedCount() {
                var checkedBoxes = $('#taskTable tbody .task-checkbox:checked');
                var count = checkedBoxes.length;
                var hasPending = checkedBoxes.filter('[data-done="false"]').length > 0;
                var hasDone = checkedBoxes.filter('[data-done="true"]').length > 0;
                $('#btnMarkDone').prop('disabled', !hasPending);
                $('#btnMarkUndone').prop('disabled', !hasDone);
                $('#selectedCount').text(count > 0 ? 'Đã chọn ' + count + ' task' : '');
            }

            // Bulk mark done
            $('#btnMarkDone').on('click', function () {
                var ids = [];
                $('#taskTable tbody .task-checkbox:checked').each(function () {
                    ids.push(parseInt($(this).val()));
                });
                if (ids.length === 0) return;

                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span> Đang xử lý...');

                $.ajax({
                    url: '/Tasks?handler=MarkDone',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    data: JSON.stringify({ ids: ids }),
                    success: function (res) {
                        if (res.success) {
                            toastr.success('Đã đánh dấu hoàn thành ' + res.updated + ' task.');
                            table.ajax.reload(null, false);
                        }
                    },
                    error: function (xhr) {
                        console.error('Mark done error:', xhr);
                        toastr.error('Lỗi khi cập nhật trạng thái.');
                    },
                    complete: function () {
                        btn.prop('disabled', false).html('<i class="bi bi-check2-square"></i> Đã hoàn thành');
                        updateSelectedCount();
                    }
                });
            });

            // Bulk mark undone
            $('#btnMarkUndone').on('click', function () {
                var ids = [];
                $('#taskTable tbody .task-checkbox:checked').filter('[data-done="true"]').each(function () {
                    ids.push(parseInt($(this).val()));
                });
                if (ids.length === 0) return;

                var btn = $(this);
                btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm" role="status"></span> Đang xử lý...');

                $.ajax({
                    url: '/Tasks?handler=MarkUndone',
                    type: 'POST',
                    contentType: 'application/json',
                    headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                    data: JSON.stringify({ ids: ids }),
                    success: function (res) {
                        if (res.success) {
                            toastr.success('Đã chuyển ' + res.updated + ' task về chưa hoàn thành.');
                            table.ajax.reload(null, false);
                        }
                    },
                    error: function (xhr) {
                        console.error('Mark undone error:', xhr);
                        toastr.error('Lỗi khi cập nhật trạng thái.');
                    },
                    complete: function () {
                        btn.prop('disabled', false).html('<i class="bi bi-arrow-counterclockwise"></i> Chưa hoàn thành');
                        updateSelectedCount();
                    }
                });
            });

            // Search with debounce
            var searchTimeout;
            document.getElementById('taskSearch').addEventListener('input', function () {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(function () { table.ajax.reload(); }, 400);
            });

            // Filter dropdowns
            document.getElementById('filterType').addEventListener('change', function () { table.ajax.reload(); });
            document.getElementById('filterStatus').addEventListener('change', function () { table.ajax.reload(); });
        });
    </script>
}
