@page
@using Clinic.Services.Domain.Entities
@model Clinic.Web.Pages.Patients.DetailsModel
@{
    ViewData["Title"] = "Chi tiết bệnh nhân";
}

@if (Model.Patient == null)
{
    <div class="alert alert-danger" role="alert">
        Không tìm thấy bệnh nhân.
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Chi tiết bệnh nhân</h2>
        <div>
            <a class="btn btn-sm btn-outline-secondary me-2" href="/Patients">Quay lại</a>
            <a class="btn btn-sm btn-primary" href="/Appointments/Create?patientId=@Model.Patient.Id">Hẹn mới</a>
            <form method="post" asp-page-handler="CreateVisit" class="d-inline">
                <input type="hidden" name="id" value="@Model.Patient.Id" />
                <button type="submit" class="btn btn-sm btn-primary">Khám bệnh</button>
            </form>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-3">
            <div class="card p-3 patient-card text-center">
                <div class="text-center mb-3">
                    <h5 class="mb-0">@Model.Patient.FullName</h5>
                    <div class="mt-2" style="min-height: 80px; display: flex; align-items: center; justify-content: center;">
                        @if (!string.IsNullOrEmpty(Model.Patient.BarcodeValue))
                        {
                            <svg id="barcode-@Model.Patient.Id"></svg>
                        }
                    </div>
                </div>
                <ul class="list-unstyled text-start mt-3 small text-muted">
                    <li><strong>CCCD:</strong> @(Model.Patient.IdentityNumber ?? "-")</li>
                    <li><strong>Phone:</strong> @(Model.Patient.Phone ?? "-")</li>
                    <li><strong>Email:</strong> @(Model.Patient.Email ?? "-")</li>
                    <li><strong>Birth:</strong> @Model.Patient.DateOfBirth.ToString("yyyy-MM-dd")</li>
                    <li><strong>Gender:</strong> @(Model.Patient.Gender ?? "-")</li>
                    <li><strong>Address:</strong> @(Model.Patient.Address ?? "-")</li>
                </ul>

                <div class="d-grid gap-2 mt-3">
                    <a class="btn btn-outline-primary" href="/Patients/Edit?id=@Model.Patient.Id">Chỉnh sửa</a>
                </div>
            </div>

            @if (Model.NextAppointment != null)
            {
                <div class="card p-3 mt-3">
                    <h6 class="mb-3">Lịch hẹn kế tiếp</h6>
                    <div>
                        <div class="fw-semibold">@Model.NextAppointment.ScheduledAt.ToString("yyyy-MM-dd HH:mm")</div>
                        <div class="small text-muted">
                            @if (Model.NextAppointment.Staff != null)
                            {
                                <span>Dr. @Model.NextAppointment.Staff.FullName</span>
                            }
                            @if (!string.IsNullOrEmpty(Model.NextAppointment.Reason))
                            {
                                <span>— @Model.NextAppointment.Reason</span>
                            }
                        </div>
                        <div class="mt-3 d-flex gap-2">
                            <a class="btn btn-sm btn-primary" href="/Appointments/@Model.NextAppointment.Id">Xem</a>
                            <a class="btn btn-sm btn-outline-secondary" href="/Appointments/Edit?id=@Model.NextAppointment.Id">Đổi lịch</a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-9">
            <div class="card p-3 mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Lịch sử khám</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0" id="visitHistoryTable" style="font-size:0.85rem;">
                        <thead class="table-light">
                            <tr>
                                <th>Ngày khám</th>
                                <th>Bác sĩ</th>
                                <th>Chẩn đoán</th>
                                <th>Triệu chứng</th>
                                <th style="width:80px;"></th>
                            </tr>
                        </thead>
                        <tbody id="visitHistoryBody">
                            <tr>
                                <td colspan="5" class="text-center py-3">
                                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                                    <span class="ms-2 text-muted">Đang tải...</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-2" id="visitHistoryPager" style="display:none !important;">
                    <div class="small text-muted" id="visitHistoryInfo"></div>
                    <nav>
                        <ul class="pagination pagination-sm mb-0" id="visitHistoryPages"></ul>
                    </nav>
                </div>
            </div>

            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Hoạt động gần đây</h5>
                    <div class="d-flex gap-1 flex-wrap">
                        <button class="btn btn-sm btn-outline-primary active feed-filter" data-type="all">Tất cả</button>
                        <button class="btn btn-sm btn-outline-secondary feed-filter" data-type="Post">Bài viết</button>
                        <button class="btn btn-sm btn-outline-secondary feed-filter" data-type="BirthdayGreeting">Sinh nhật</button>
                        <button class="btn btn-sm btn-outline-secondary feed-filter" data-type="AppointmentCreated">Lịch hẹn</button>
                        <button class="btn btn-sm btn-outline-secondary feed-filter" data-type="HistoryRecordAdded">Kết quả</button>
                        <button class="btn btn-sm btn-outline-secondary feed-filter" data-type="SurgeryScheduled">Phẫu thuật</button>
                    </div>
                </div>

                <div class="feed-composer mb-3">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2 align-items-start">
                        <div class="feed-avatar flex-shrink-0">👤</div>
                        <div class="flex-grow-1">
                            <textarea id="postContent" class="form-control form-control-sm" rows="2"
                                placeholder="Viết ghi chú về bệnh nhân @Model.Patient.FullName..."
                                style="resize: vertical;"></textarea>
                            <div id="imagePreviewContainer" class="d-flex flex-wrap gap-2 mt-2" style="display:none !important;"></div>
                            <input type="file" id="postImages" multiple accept="image/*" style="display:none;" />
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <button type="button" class="btn btn-outline-secondary btn-sm" id="btnPickImages" title="Thêm ảnh">
                                    📷 Ảnh
                                </button>
                                <div class="d-flex gap-2 align-items-center">
                                    <span id="postCharCount" class="text-muted small"></span>
                                    <button class="btn btn-primary btn-sm px-3" id="btnPost" disabled>
                                        Đăng
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="activityFeed" class="activity-feed">
                    <div class="text-center py-4" id="feedLoading">
                        <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                        <span class="ms-2 text-muted">Đang tải...</span>
                    </div>
                </div>

                <div class="text-center mt-3" id="loadMoreContainer" style="display:none;">
                    <button class="btn btn-outline-primary btn-sm" id="btnLoadMore">
                        Xem thêm hoạt động
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/moment@2.30.1/min/moment-with-locales.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            moment.locale('vi');
            // Generate barcode
            const barcodeElement = document.getElementById('barcode-@Model.Patient.Id');
            const barcodeValue = '@Model.Patient.BarcodeValue';

            if (barcodeElement && barcodeValue) {
                try {
                    JsBarcode('#barcode-@Model.Patient.Id', barcodeValue, {
                        format: 'CODE128',
                        width: 2,
                        height: 50,
                        displayValue: true,
                        fontSize: 14,
                        margin: 10
                    });
                } catch (e) {
                    console.error('Barcode generation error:', e);
                }
            }

            const patientId = @(Model.Patient?.Id ?? 0);

            // ===== VISIT HISTORY (AJAX PAGING) =====
            let visitPage = 1;
            const visitPageSize = 10;
            const visitBody = document.getElementById('visitHistoryBody');
            const visitPager = document.getElementById('visitHistoryPager');
            const visitInfo = document.getElementById('visitHistoryInfo');
            const visitPages = document.getElementById('visitHistoryPages');

            async function loadVisitHistory(page) {
                visitPage = page;
                try {
                    const res = await fetch(`/Patients/Details?handler=VisitHistory&id=${patientId}&pageNumber=${page}&pageSize=${visitPageSize}`);
                    const json = await res.json();

                    if (!json.data || json.data.length === 0) {
                        visitBody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">Không có lịch sử khám.</td></tr>';
                        visitPager.style.cssText = 'display:none !important;';
                        return;
                    }

                    let html = '';
                    json.data.forEach(function (r) {
                        const diagnosis = r.diagnosis || '-';
                        const symptoms = r.symptoms || '-';
                        const m = moment(r.visitDate, 'YYYY-MM-DD HH:mm');
                        const dateDisplay = '<span title="' + m.format('DD/MM/YYYY HH:mm') + '">' + m.fromNow() + '</span>';
                        html += '<tr>' +
                            '<td>' + dateDisplay + '</td>' +
                            '<td>' + r.staffName + '</td>' +
                            '<td>' + diagnosis + '</td>' +
                            '<td class="small text-muted">' + symptoms + '</td>' +
                            '<td><a class="btn btn-sm btn-outline-primary" href="/Visits/HealthRecord?id=' + r.id + '" style="font-size:0.75rem;padding:0.15rem 0.4rem;">Chi tiết</a></td>' +
                            '</tr>';
                    });
                    visitBody.innerHTML = html;

                    // Pager
                    const start = (json.pageNumber - 1) * json.pageSize + 1;
                    const end = Math.min(json.pageNumber * json.pageSize, json.totalCount);
                    visitInfo.textContent = 'Hiển thị ' + start + '-' + end + ' / ' + json.totalCount + ' lần khám';

                    let pagesHtml = '';
                    pagesHtml += '<li class="page-item ' + (json.pageNumber <= 1 ? 'disabled' : '') + '">' +
                        '<a class="page-link" href="javascript:void(0)" onclick="loadVisitHistory(' + (json.pageNumber - 1) + ')">&laquo;</a></li>';
                    for (let i = 1; i <= json.totalPages; i++) {
                        pagesHtml += '<li class="page-item ' + (i === json.pageNumber ? 'active' : '') + '">' +
                            '<a class="page-link" href="javascript:void(0)" onclick="loadVisitHistory(' + i + ')">' + i + '</a></li>';
                    }
                    pagesHtml += '<li class="page-item ' + (json.pageNumber >= json.totalPages ? 'disabled' : '') + '">' +
                        '<a class="page-link" href="javascript:void(0)" onclick="loadVisitHistory(' + (json.pageNumber + 1) + ')">&raquo;</a></li>';
                    visitPages.innerHTML = pagesHtml;

                    visitPager.style.cssText = json.totalPages > 1 ? '' : 'display:none !important;';
                } catch (err) {
                    console.error('Error loading visit history:', err);
                    visitBody.innerHTML = '<tr><td colspan="5" class="text-center text-danger py-3">Lỗi khi tải dữ liệu.</td></tr>';
                }
            }

            // Expose globally for inline onclick
            window.loadVisitHistory = loadVisitHistory;

            if (patientId > 0) {
                loadVisitHistory(1);
            }

            // ===== POST COMPOSER =====
            const postContent = document.getElementById('postContent');
            const btnPost = document.getElementById('btnPost');
            const postCharCount = document.getElementById('postCharCount');
            const btnPickImages = document.getElementById('btnPickImages');
            const postImagesInput = document.getElementById('postImages');
            const imagePreviewContainer = document.getElementById('imagePreviewContainer');
            let selectedFiles = [];

            function updatePostButton() {
                const hasText = postContent.value.trim().length > 0;
                const hasImages = selectedFiles.length > 0;
                btnPost.disabled = !hasText && !hasImages;
            }

            function renderImagePreviews() {
                imagePreviewContainer.innerHTML = '';
                if (selectedFiles.length === 0) {
                    imagePreviewContainer.style.display = 'none';
                    return;
                }
                imagePreviewContainer.style.cssText = 'display: flex !important;';
                selectedFiles.forEach((file, i) => {
                    const url = URL.createObjectURL(file);
                    const wrap = document.createElement('div');
                    wrap.className = 'position-relative';
                    wrap.style.cssText = 'width:72px;height:72px;';
                    wrap.innerHTML = `<img src="${url}" style="width:72px;height:72px;object-fit:cover;border-radius:6px;border:1px solid #dee2e6;" />
                        <button type="button" class="btn btn-sm btn-danger position-absolute top-0 end-0"
                            style="width:20px;height:20px;padding:0;font-size:0.65rem;line-height:20px;border-radius:50%;transform:translate(30%,-30%);"
                            data-remove-idx="${i}">&times;</button>`;
                    imagePreviewContainer.appendChild(wrap);
                });
                // Remove button handler
                imagePreviewContainer.querySelectorAll('[data-remove-idx]').forEach(btn => {
                    btn.addEventListener('click', function () {
                        selectedFiles.splice(parseInt(this.dataset.removeIdx), 1);
                        renderImagePreviews();
                        updatePostButton();
                    });
                });
            }

            if (btnPickImages && postImagesInput) {
                btnPickImages.addEventListener('click', () => postImagesInput.click());
                postImagesInput.addEventListener('change', function () {
                    const newFiles = Array.from(this.files).filter(f => f.size <= 5 * 1024 * 1024);
                    selectedFiles = selectedFiles.concat(newFiles);
                    renderImagePreviews();
                    updatePostButton();
                    this.value = '';
                });
            }

            if (postContent && btnPost) {
                postContent.addEventListener('input', function () {
                    const len = this.value.trim().length;
                    postCharCount.textContent = len > 0 ? `${len} ký tự` : '';
                    updatePostButton();
                });

                // Auto-expand textarea
                postContent.addEventListener('input', function () {
                    this.style.height = 'auto';
                    this.style.height = Math.min(this.scrollHeight, 160) + 'px';
                });

                btnPost.addEventListener('click', async function () {
                    const text = postContent.value.trim();
                    if (!text && selectedFiles.length === 0) return;

                    btnPost.disabled = true;
                    btnPost.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';

                    try {
                        const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
                        const formData = new FormData();
                        formData.append('patientId', patientId);
                        formData.append('contentText', text);
                        selectedFiles.forEach(f => formData.append('files', f));

                        const res = await fetch(`/Patients/Details?handler=CreateActivity`, {
                            method: 'POST',
                            headers: {
                                'RequestVerificationToken': token || ''
                            },
                            body: formData
                        });

                        if (!res.ok) throw new Error('Post failed');
                        const newActivity = await res.json();

                        // Prepend new card to feed
                        const cardHtml = renderActivityCard(newActivity);
                        const feedFirstCard = feed.querySelector('.feed-card');
                        if (feedFirstCard) {
                            feedFirstCard.insertAdjacentHTML('beforebegin', cardHtml);
                        } else {
                            feed.insertAdjacentHTML('afterbegin', cardHtml);
                        }
                        allItems.unshift(newActivity);
                        applyFeedFilter();

                        // Reset composer
                        postContent.value = '';
                        postContent.style.height = 'auto';
                        postCharCount.textContent = '';
                        selectedFiles = [];
                        renderImagePreviews();
                    } catch (err) {
                        console.error('Error posting activity:', err);
                        alert('Lỗi khi đăng bài viết. Vui lòng thử lại.');
                    }

                    btnPost.disabled = false;
                    btnPost.innerHTML = 'Đăng';
                });

                // Ctrl+Enter to post
                postContent.addEventListener('keydown', function (e) {
                    if (e.ctrlKey && e.key === 'Enter' && !btnPost.disabled) {
                        btnPost.click();
                    }
                });
            }

            // ===== ACTIVITY NEWSFEED =====
            const feed = document.getElementById('activityFeed');
            const feedLoading = document.getElementById('feedLoading');
            const loadMoreContainer = document.getElementById('loadMoreContainer');
            const btnLoadMore = document.getElementById('btnLoadMore');
            let currentPage = 0;
            let activeFilter = 'all';
            let isLoading = false;
            let allItems = []; // store all loaded items for client-side filtering

            const typeIcons = {
                'Post': '📝',
                'BirthdayGreeting': '🎂',
                'AppointmentCreated': '📅',
                'HistoryRecordAdded': '📋',
                'SurgeryScheduled': '🏥',
                'PatientRegistered': '👤',
                'General': '📌'
            };

            const typeBadgeClass = {
                'Post': 'bg-primary',
                'BirthdayGreeting': 'bg-warning text-dark',
                'AppointmentCreated': 'bg-info text-dark',
                'HistoryRecordAdded': 'bg-success',
                'SurgeryScheduled': 'bg-danger',
                'PatientRegistered': 'bg-secondary',
                'General': 'bg-dark'
            };

            function buildImageGrid(images, galleryId) {
                if (!images || images.length === 0) return '';
                // Store images for lightbox navigation
                window._galleries = window._galleries || {};
                window._galleries[galleryId] = images.map(img => img.imageUrl);
                const count = images.length;

                if (count === 1) {
                    return `<div class="feed-images mt-2">
                        <img src="${images[0].imageUrl}" alt="${images[0].caption || ''}" class="feed-img feed-img-single" onclick="openImageViewer('${galleryId}', 0)" />
                    </div>`;
                }
                if (count === 2) {
                    return `<div class="feed-images feed-images-2 mt-2">
                        ${images.map((img, i) => `<img src="${img.imageUrl}" alt="${img.caption || ''}" class="feed-img" onclick="openImageViewer('${galleryId}', ${i})" />`).join('')}
                    </div>`;
                }
                // 3+ images: show first 3 in grid, with +N overlay on the 3rd if more
                const shown = images.slice(0, 3);
                const extra = count - 3;
                let html = `<div class="feed-images feed-images-grid mt-2">`;
                html += `<img src="${shown[0].imageUrl}" alt="${shown[0].caption || ''}" class="feed-img feed-img-main" onclick="openImageViewer('${galleryId}', 0)" />`;
                html += `<div class="feed-img-side">`;
                html += `<img src="${shown[1].imageUrl}" alt="${shown[1].caption || ''}" class="feed-img" onclick="openImageViewer('${galleryId}', 1)" />`;
                html += `<div class="feed-img-last-wrap">`;
                html += `<img src="${shown[2].imageUrl}" alt="${shown[2].caption || ''}" class="feed-img" onclick="openImageViewer('${galleryId}', 2)" />`;
                if (extra > 0) {
                    html += `<div class="feed-img-overlay" onclick="openImageViewer('${galleryId}', 2)">+${extra}</div>`;
                }
                html += `</div></div></div>`;
                return html;
            }

            function renderActivityCard(a) {
                const icon = typeIcons[a.activityType] || '📌';
                const badgeClass = typeBadgeClass[a.activityType] || 'bg-dark';
                const galleryId = 'gallery-' + a.id;
                const avatarHtml = a.avatarUrl
                    ? `<img src="${a.avatarUrl}" style="width:40px;height:40px;border-radius:50%;object-fit:cover;" />`
                    : icon;

                return `
                <div class="feed-card" data-type="${a.activityType}">
                    <div class="feed-card-header">
                        <div class="feed-avatar">${avatarHtml}</div>
                        <div class="feed-meta">
                            <div class="feed-author">${a.createdBy}</div>
                            <div class="feed-time">${a.createdDateRelative} · <span class="badge ${badgeClass} badge-sm">${a.activityTypeDisplay}</span></div>
                        </div>
                    </div>
                    <div class="feed-card-body">
                        <p class="feed-content">${a.contentText}</p>
                        ${buildImageGrid(a.images, galleryId)}
                    </div>
                    <div class="feed-card-footer">
                        ${a.images.length > 0 ? `<span class="text-muted small">${a.images.length} ảnh</span>` : ''}
                    </div>
                </div>`;
            }

            function applyFeedFilter() {
                const cards = feed.querySelectorAll('.feed-card');
                cards.forEach(card => {
                    if (activeFilter === 'all' || card.dataset.type === activeFilter) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });
            }

            async function loadActivities() {
                if (isLoading) return;
                isLoading = true;
                currentPage++;

                try {
                    const res = await fetch(`/Patients/Details?handler=Activities&id=${patientId}&pageNumber=${currentPage}&pageSize=10`);
                    const json = await res.json();

                    if (feedLoading) feedLoading.style.display = 'none';

                    if (json.data && json.data.length > 0) {
                        let html = '';
                        json.data.forEach(a => {
                            allItems.push(a);
                            html += renderActivityCard(a);
                        });
                        feed.insertAdjacentHTML('beforeend', html);
                        applyFeedFilter();
                    }

                    if (json.hasMore) {
                        loadMoreContainer.style.display = '';
                    } else {
                        loadMoreContainer.style.display = 'none';
                        if (allItems.length > 0) {
                            feed.insertAdjacentHTML('beforeend',
                                '<div class="text-center text-muted small py-3">— Đã hiển thị tất cả hoạt động —</div>');
                        }
                    }
                } catch (err) {
                    console.error('Error loading activities:', err);
                    if (feedLoading) feedLoading.innerHTML = '<span class="text-danger">Lỗi khi tải dữ liệu.</span>';
                }
                isLoading = false;
            }

            // Load first page
            if (patientId > 0) {
                loadActivities();
            }

            // Load more button
            if (btnLoadMore) {
                btnLoadMore.addEventListener('click', loadActivities);
            }

            // Filter buttons
            document.querySelectorAll('.feed-filter').forEach(btn => {
                btn.addEventListener('click', function () {
                    document.querySelectorAll('.feed-filter').forEach(b => {
                        b.classList.remove('active', 'btn-outline-primary');
                        b.classList.add('btn-outline-secondary');
                    });
                    this.classList.remove('btn-outline-secondary');
                    this.classList.add('active', 'btn-outline-primary');
                    activeFilter = this.dataset.type;
                    applyFeedFilter();
                });
            });
        });

        // Image lightbox with Previous / Next navigation
        function openImageViewer(galleryId, index) {
            const images = (window._galleries || {})[galleryId];
            if (!images || images.length === 0) return;

            let current = index;

            // Remove existing viewer if any
            const existing = document.getElementById('imgViewerOverlay');
            if (existing) existing.remove();

            const overlay = document.createElement('div');
            overlay.id = 'imgViewerOverlay';
            overlay.className = 'feed-image-viewer';
            overlay.innerHTML = `
                <div class="feed-image-viewer-backdrop"></div>
                <img class="feed-image-viewer-img" />
                <div class="feed-image-viewer-counter"></div>
                <button class="btn feed-image-viewer-close">&times;</button>
                <button class="btn feed-image-viewer-prev">&#10094;</button>
                <button class="btn feed-image-viewer-next">&#10095;</button>`;
            document.body.appendChild(overlay);

            const img = overlay.querySelector('.feed-image-viewer-img');
            const counter = overlay.querySelector('.feed-image-viewer-counter');
            const btnPrev = overlay.querySelector('.feed-image-viewer-prev');
            const btnNext = overlay.querySelector('.feed-image-viewer-next');
            const btnClose = overlay.querySelector('.feed-image-viewer-close');
            const backdrop = overlay.querySelector('.feed-image-viewer-backdrop');

            function show(i) {
                current = i;
                img.src = images[current];
                counter.textContent = images.length > 1 ? `${current + 1} / ${images.length}` : '';
                btnPrev.style.display = images.length > 1 ? '' : 'none';
                btnNext.style.display = images.length > 1 ? '' : 'none';
            }

            function close() { overlay.remove(); document.removeEventListener('keydown', onKey); }
            function prev() { show((current - 1 + images.length) % images.length); }
            function next() { show((current + 1) % images.length); }

            function onKey(e) {
                if (e.key === 'Escape') close();
                else if (e.key === 'ArrowLeft') prev();
                else if (e.key === 'ArrowRight') next();
            }

            backdrop.addEventListener('click', close);
            btnClose.addEventListener('click', close);
            btnPrev.addEventListener('click', function (e) { e.stopPropagation(); prev(); });
            btnNext.addEventListener('click', function (e) { e.stopPropagation(); next(); });
            document.addEventListener('keydown', onKey);

            show(current);
        }
    </script>
}

