@page
@model WebApplication1.Pages.Patients.IndexModel
@{
    ViewData["Title"] = "Patients";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Patients</h2>
    <div>
        <a class="btn btn-sm btn-primary" href="">New Patient</a>
    </div>
</div>

<style>
    .table-patients thead tr {
        /* nền header dùng màu dark olive từ color palette */
        background-color: #363B2C;
    }

    .table-patients thead .sortable-header:hover {
    }

    .pagination .page-link {
        color: var(--bs-primary);
    }

    .pagination .page-item.active .page-link {
        background-color: var(--bs-primary);
        border-color: var(--bs-primary);
    }
</style>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-5">
            <input class="form-control" placeholder="Search by name or ID" />
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-12">
        <div class="card p-3">
            <h5 class="mb-3">Patient List</h5>
            <div class="d-flex justify-content-between align-items-center mb-2 small text-muted">
                <div>
                    Showing @Model.Patients.Count of @Model.TotalCount patients
                </div>
                <div>
                    Page @Model.CurrentPage of @Model.TotalPages
                </div>
            </div>
            <div class="table-responsive">
                <table class="table align-middle table-patients">
                    <thead>
                        <tr>
                            <th>
                                <a class="sortable-header @(Model.SortBy == "name" ? "active" : "")"
                                   asp-page="./Index"
                                   asp-route-pageNumber="1"
                                   asp-route-sortBy="name"
                                   asp-route-sortDir="@(Model.SortBy == "name" && Model.SortDir == "asc" ? "desc" : "asc")">
                                    Patient
                                    @if (Model.SortBy == "name")
                                    {
                                        <span class="sort-icon">@((Model.SortDir == "asc") ? "▲" : "▼")</span>
                                    }
                                </a>
                            </th>
                            <th>
                                <a class="sortable-header @(Model.SortBy == "phone" ? "active" : "")"
                                   asp-page="./Index"
                                   asp-route-pageNumber="1"
                                   asp-route-sortBy="phone"
                                   asp-route-sortDir="@(Model.SortBy == "phone" && Model.SortDir == "asc" ? "desc" : "asc")">
                                    Phone
                                    @if (Model.SortBy == "phone")
                                    {
                                        <span class="sort-icon">@((Model.SortDir == "asc") ? "▲" : "▼")</span>
                                    }
                                </a>
                            </th>
                            <th>
                                <a class="sortable-header @(Model.SortBy == "lastvisit" ? "active" : "")"
                                   asp-page="./Index"
                                   asp-route-pageNumber="1"
                                   asp-route-sortBy="lastvisit"
                                   asp-route-sortDir="@(Model.SortBy == "lastvisit" && Model.SortDir == "asc" ? "desc" : "asc")">
                                    Last visit
                                    @if (Model.SortBy == "lastvisit")
                                    {
                                        <span class="sort-icon">@((Model.SortDir == "asc") ? "▲" : "▼")</span>
                                    }
                                </a>
                            </th>
                            <th>Ngày tái khám (dự tính)</th>
                            <th>Confirm (từ khách hàng)</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Patients.Any())
                        {
                            foreach (var p in Model.Patients)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <img src="https://via.placeholder.com/44" class="rounded-circle me-2" alt="">
                                            <div>
                                                <div class="fw-semibold">
                                                    <a class="text-decoration-none patient-link" href="/Patients/Details?id=@p.Id">@p.FullName</a>
                                                </div>
                                                <div class="small text-muted">PT-@p.Id.ToString("D5")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>@p.Phone</td>
                                    <td>-</td>
                                    <td>-</td>
                                    <td><span class="badge bg-secondary">N/A</span></td>
                                    <td>
                                        <a class="btn btn-sm btn-outline-primary me-1" href="">Edit</a>
                                        <a class="btn btn-sm btn-outline-secondary" href="/Patients/Details?id=@p.Id">Details</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">Không có bệnh nhân nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

                        @if (Model.TotalPages > 1)
            {
                <nav aria-label="Patient pagination">
                    <ul class="pagination pagination-sm justify-content-end mt-3">
                        <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                            <a class="page-link"
                               asp-page="./Index"
                               asp-route-pageNumber="@(Model.CurrentPage - 1)"
                               asp-route-sortBy="@Model.SortBy"
                               asp-route-sortDir="@Model.SortDir">Previous</a>
                        </li>
                        @{
                            var startPage = Math.Max(1, Model.CurrentPage - 2);
                            var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);
                        }
                        @if (startPage > 1)
                        {
                            <li class="page-item @(1 == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-page="./Index"
                                   asp-route-pageNumber="1"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortDir="@Model.SortDir">1</a>
                            </li>
                            @if (startPage > 2)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                        }
                        @for (var i = startPage; i <= endPage; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-page="./Index"
                                   asp-route-pageNumber="@i"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortDir="@Model.SortDir">@i</a>
                            </li>
                        }
                        @if (endPage < Model.TotalPages)
                        {
                            @if (endPage < Model.TotalPages - 1)
                            {
                                <li class="page-item disabled"><span class="page-link">...</span></li>
                            }
                            <li class="page-item @(Model.TotalPages == Model.CurrentPage ? "active" : "")">
                                <a class="page-link"
                                   asp-page="./Index"
                                   asp-route-pageNumber="@Model.TotalPages"
                                   asp-route-sortBy="@Model.SortBy"
                                   asp-route-sortDir="@Model.SortDir">@Model.TotalPages</a>
                            </li>
                        }
                        <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link"
                               asp-page="./Index"
                               asp-route-pageNumber="@(Model.CurrentPage + 1)"
                               asp-route-sortBy="@Model.SortBy"
                               asp-route-sortDir="@Model.SortDir">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>
