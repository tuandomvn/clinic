@page
@model Clinic.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DR.VUHUAN Clinic Management</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/custom-theme.css" rel="stylesheet" />
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            height: 100%;
            width: 100%;
        }

        body {
            background: linear-gradient(135deg, #363B2C 0%, #2a2e23 50%, #70A19A 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            min-height: 100vh;
        }

        .login-container {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 450px;
            width: 90%;
            padding: 50px 40px;
            position: relative;
            overflow: hidden;
        }

        .login-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 6px;
            background: linear-gradient(90deg, #363B2C 0%, #70A19A 100%);
        }

        .login-header {
            text-align: center;
            margin-bottom: 40px;
        }

        .login-header .logo {
            display: inline-block;
            width: 60px;
            height: 60px;
            background: linear-gradient(135deg, #363B2C 0%, #70A19A 100%);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 20px;
            color: white;
            font-size: 32px;
            font-weight: bold;
        }

        .login-header h1 {
            color: #363B2C;
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
            letter-spacing: -0.5px;
        }

        .login-header p {
            color: #70A19A;
            font-size: 14px;
            margin: 0;
            font-weight: 500;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            font-weight: 600;
            color: #363B2C;
            margin-bottom: 8px;
            display: block;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .form-control {
            border: 2px solid #E5E5E5;
            border-radius: 8px;
            padding: 12px 16px;
            font-size: 14px;
            transition: all 0.3s ease;
            background-color: #f8f9fa;
        }

        .form-control:focus {
            border-color: #70A19A;
            background-color: #ffffff;
            box-shadow: 0 0 0 3px rgba(112, 161, 154, 0.1);
            outline: none;
        }

        .form-control::placeholder {
            color: #999;
        }

        .btn-login {
            background: linear-gradient(135deg, #363B2C 0%, #2a2e23 100%);
            border: none;
            color: white;
            font-weight: 600;
            padding: 13px 20px;
            border-radius: 8px;
            width: 100%;
            transition: all 0.3s ease;
            font-size: 15px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: 10px;
        }

        .btn-login:hover {
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 10px 25px rgba(54, 59, 44, 0.3);
            background: linear-gradient(135deg, #2a2e23 0%, #1f2219 100%);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login:disabled {
            opacity: 0.7;
            cursor: not-allowed;
            transform: none;
        }

        .alert-danger-custom {
            background-color: #fff5f5;
            border: 2px solid #f5a6a6;
            color: #721c24;
            border-radius: 8px;
            padding: 14px 16px;
            margin-bottom: 24px;
            font-size: 14px;
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .alert-danger-custom::before {
            content: '⚠️';
            flex-shrink: 0;
            font-size: 18px;
        }

        .remember-me {
            display: flex;
            align-items: center;
            margin-bottom: 24px;
            gap: 8px;
        }

        .remember-me input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #70A19A;
        }

        .remember-me label {
            margin: 0;
            cursor: pointer;
            font-size: 14px;
            color: #555;
            user-select: none;
        }

        .footer-text {
            text-align: center;
            font-size: 12px;
            color: #999;
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #E5E5E5;
        }

        .footer-text p {
            margin: 4px 0;
        }

        .footer-text strong {
            color: #363B2C;
        }

        .loading-spinner {
            display: none;
            margin-right: 8px;
        }

        .spinner-border-sm {
            width: 1rem;
            height: 1rem;
            border-width: 0.2em;
        }

        /* Responsive */
        @@media (max-width: 576px) {
            .login-container {
                padding: 40px 24px;
                width: 95%;
            }

            .login-header h1 {
                font-size: 24px;
            }

            .btn-login {
                padding: 12px 16px;
                font-size: 14px;
            }
        }

        /* Focus visible for accessibility */
        .form-control:focus-visible {
            outline: 2px solid #70A19A;
            outline-offset: 2px;
        }

        /* Success animation */
        @@keyframes slideInSuccess {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-danger-custom {
            animation: slideInSuccess 0.3s ease-out;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <div class="logo">🏥</div>
            <h1>DR.VUHUAN</h1>
            <p>Hệ thống quản lý phòng khám</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-danger-custom" role="alert">
                <div>
                    <strong>Lỗi!</strong> @Model.ErrorMessage
                </div>
            </div>
        }

        <form method="post" class="login-form">
            <div class="form-group">
                <label class="form-label" for="username">Tên đăng nhập</label>
                <input type="text"
                       class="form-control"
                       id="username"
                       name="Input.Username"
                       placeholder="Nhập tên đăng nhập"
                       required
                       autocomplete="username"
                       value="@Model.Input.Username" />
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Mật khẩu</label>
                <input type="password"
                       class="form-control"
                       id="password"
                       name="Input.Password"
                       placeholder="Nhập mật khẩu"
                       required
                       autocomplete="current-password" />
            </div>

            <div class="remember-me">
                <input type="checkbox" id="rememberMe" name="rememberMe" />
                <label for="rememberMe">Ghi nhớ đăng nhập</label>
            </div>

            <button type="submit" class="btn-login" id="submitBtn">
                <span class="loading-spinner" id="spinner">
                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                </span>
                Đăng nhập
            </button>
        </form>

        <div class="footer-text">
            <p><strong>DR.VUHUAN Clinic Management System</strong></p>
            <p>© 2024 - Hệ thống quản lý phòng khám</p>
            <p style="margin-top: 8px; color: #bbb;">support@dr-vuhuan.local</p>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Handle form submission
        document.querySelector('.login-form').addEventListener('submit', function () {
            const spinner = document.getElementById('spinner');
            const btn = document.getElementById('submitBtn');
            spinner.style.display = 'inline-block';
            btn.disabled = true;
        });

        // Auto-focus on username input
        document.getElementById('username').focus();

        // Handle Enter key on password field
        document.getElementById('password').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                document.querySelector('.login-form').submit();
            }
        });
    </script>
</body>
</html>
