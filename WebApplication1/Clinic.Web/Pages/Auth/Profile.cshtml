@page
@model Clinic.Web.Pages.Auth.ProfileModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Thông tin cá nhân</h2>
    <div>
        <a class="btn btn-sm btn-outline-secondary" asp-page="/Index">Quay lại</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-3">
        <div class="card p-4 text-center">
            <div class="mb-3">
                @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                {
                    <img src="@Model.AvatarUrl" alt="Avatar" class="rounded-circle" style="width: 120px; height: 120px; object-fit: cover;" />
                }
                else
                {
                    <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center mx-auto text-white" style="width: 120px; height: 120px; font-size: 2.5rem;">
                        @(Model.Input.FullName.Length > 0 ? Model.Input.FullName[0] : '?')
                    </div>
                }
            </div>
            <h6 class="mb-1">@Model.Input.FullName</h6>
            <div class="small text-muted mb-3">@Model.Input.StaffType</div>
            <form method="post" asp-page-handler="UploadAvatar" enctype="multipart/form-data">
                <div class="mb-2">
                    <input type="file" name="avatar" accept=".jpg,.jpeg,.png,.webp" class="form-control form-control-sm" id="avatarInput" />
                </div>
                <div class="small text-muted mb-2">JPG, PNG hoặc WebP. Tối đa 2MB.</div>
                <button type="submit" class="btn btn-sm btn-outline-primary w-100">Cập nhật ảnh</button>
            </form>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card p-4">
            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Input.FullName" class="form-label">Họ tên <span class="text-danger">*</span></label>
                        <input asp-for="Input.FullName" class="form-control" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label">Chức vụ</label>
                        <input class="form-control" value="@Model.Input.StaffType" disabled />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Input.Specialization" class="form-label">Chuyên khoa</label>
                        <input asp-for="Input.Specialization" class="form-control" placeholder="Nội khoa" />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Input.Phone" class="form-label">Số điện thoại</label>
                        <input asp-for="Input.Phone" class="form-control" placeholder="0901234567" />
                        <span asp-validation-for="Input.Phone" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Email</label>
                        <input class="form-control" value="@Model.Input.Email" disabled />
                    </div>

                    <div class="col-12 text-end mt-4">
                        <a class="btn btn-outline-secondary me-2" asp-page="/Index">Hủy</a>
                        <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('avatarInput')?.addEventListener('change', function () {
            if (this.files && this.files[0]) {
                if (this.files[0].size > 2 * 1024 * 1024) {
                    alert('File ảnh không được vượt quá 2MB.');
                    this.value = '';
                }
            }
        });
    </script>
}
