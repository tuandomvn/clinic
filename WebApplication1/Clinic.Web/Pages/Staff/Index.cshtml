@page
@model Clinic.Web.Pages.Staff.IndexModel
@{
    ViewData["Title"] = "Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Nhân viên</h2>
    <div>
        <a class="btn btn-sm btn-primary" href="/Staff/Create">Thêm nhân viên</a>
    </div>
</div>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-5">
            <input class="form-control" placeholder="Search by name or specialty" />
        </div>
        <div class="col-md-3">
            <select class="form-select">
                <option>All specialties</option>
                <option>General</option>
                <option>Pediatrics</option>
                <option>Cardiology</option>
            </select>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-3">
        <div class="card p-3 text-center">
            <img src="~/images/bac si 1.png" class="doctor-img" alt="Dr. avatar" />

            <h5 class="mb-0">Dr. Tran Thi B</h5>
            <div class="small text-muted">General Practitioner</div>
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-secondary" href="#">Profile</a>
            </div>
        </div>
    </div>

    <div class="col-lg-9">
        <div class="card p-3">
            <h5 class="mb-3">Doctor Directory</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Doctor</th>
                            <th>Specialty</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Staffs.Any())
                        {
                            foreach (var s in Model.Staffs)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div>
                                                <div class="fw-semibold">@s.FullName</div>
                                                <div class="small text-muted">@s.Email</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(s.Specialization))
                                        {
                                            @s.Specialization
                                        }
                                        else
                                        {
                                            @s.StaffType.ToString()
                                        }
                                    </td>
                                    <td>
                                        <a class="btn btn-sm btn-outline-primary me-1" href="/Staff/Edit?id=@s.Id">Edit</a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="text-center text-muted">Không có nhân viên nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
