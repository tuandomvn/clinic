@page
@model Clinic.Web.Pages.Staff.IndexModel
@{
    ViewData["Title"] = "Nhân viên";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Nhân viên</h2>
    <div>
        <a class="btn btn-sm btn-primary" href="/Staff/Create">Thêm nhân viên</a>
    </div>
</div>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-5">
            <input id="staffSearch" class="form-control" placeholder="Tìm theo tên, email, chuyên khoa hoặc SĐT" />
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-12">
        <div class="card p-3">
            <h5 class="mb-3">Danh sách nhân viên</h5>
            <div class="table-responsive">
                <table id="staffTable" class="table table-striped table-hover" style="width:100%">
                    <thead>
                        <tr>
                            <th>Nhân viên</th>
                            <th>Chuyên khoa</th>
                            <th>Chức vụ</th>
                            <th>Điện thoại</th>
                            <th>Tài khoản</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        #staffTable {
            font-size: 0.875rem;
        }
        #staffTable thead {
            background-color: #f8f9fa;
            border-bottom: 2px solid #dee2e6;
        }
        #staffTable thead th {
            padding: 0.75rem;
            vertical-align: middle;
            font-weight: 600;
            color: #212529;
            border-bottom: 2px solid #dee2e6;
            user-select: none;
        }
        #staffTable thead th:hover {
            background-color: #e9ecef;
        }
        #staffTable thead th.sorting::after,
        #staffTable thead th.sorting_asc::after,
        #staffTable thead th.sorting_desc::after {
            content: '';
            margin-left: 0.5rem;
        }
        #staffTable tbody td {
            padding: 0.4rem 0.75rem;
            vertical-align: middle;
            border-bottom: 1px solid #dee2e6;
        }
        #staffTable tbody tr:hover {
            background-color: #f8f9fa !important;
        }
        #staffTable .small {
            font-size: 0.75rem;
        }
        #staffTable .btn-sm {
            padding: 0.25rem 0.5rem;
            font-size: 0.75rem;
        }
        .dataTables_info {
            font-size: 0.8rem;
            white-space: nowrap;
        }
        .dataTables_wrapper .dataTables_paginate {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 0 !important;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination {
            margin: 0;
            gap: 0 !important;
        }
        .dataTables_wrapper .dataTables_length {
            font-size: 0.8rem;
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_length label {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            margin: 0;
            white-space: nowrap;
            font-size: 0.8rem;
        }
        .dataTables_wrapper .dataTables_length select {
            padding: 0.2rem 1.5rem 0.2rem 0.4rem;
            font-size: 0.8rem;
            border: 1px solid #dee2e6;
            border-radius: 0.2rem;
            height: 28px;
            width: 60px;
        }
        .dataTables_wrapper {
            position: relative;
        }
        .dataTables_wrapper .row:last-child {
            display: flex !important;
            align-items: center !important;
            justify-content: flex-start !important;
            flex-wrap: nowrap !important;
            padding: 0.5rem 0 !important;
            margin: 0 !important;
            border-top: 1px solid #dee2e6;
            width: 100%;
            min-height: 32px;
        }
        .dataTables_wrapper .row:last-child > div {
            display: flex !important;
            align-items: center !important;
            flex-wrap: nowrap !important;
            gap: 1rem !important;
            flex: 1 1 auto;
            max-width: 100% !important;
            width: 100% !important;
        }
        .dataTables_wrapper .dataTables_length {
            padding: 0 !important;
            margin: 0 !important;
            flex: 0 0 auto;
            order: 1;
        }
        .dataTables_wrapper .dataTables_info {
            padding: 0 !important;
            margin: 0 !important;
            flex: 1 1 auto;
            order: 2;
            text-align: center;
        }
        .dataTables_wrapper .dataTables_paginate {
            padding: 0 !important;
            margin: 0 !important;
            flex: 0 0 auto;
            order: 3;
            gap: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination {
            margin: 0;
            gap: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .paginate_button {
            padding: 0.05rem 0.15rem;
            font-size: 0.65rem;
            min-width: 18px;
            height: 18px;
            line-height: 18px;
            margin: 0 !important;
            border-radius: 0.1rem;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item {
            margin: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item + .page-item .page-link {
            margin-left: -1px !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item .page-link {
            padding: 0.15rem 0.45rem !important;
            font-size: 0.8rem !important;
            line-height: 1.3 !important;
            min-width: auto !important;
            border-radius: 0 !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item:first-child .page-link {
            border-top-left-radius: 0.2rem !important;
            border-bottom-left-radius: 0.2rem !important;
        }
        .dataTables_wrapper .dataTables_paginate .pagination .page-item:last-child .page-link {
            border-top-right-radius: 0.2rem !important;
            border-bottom-right-radius: 0.2rem !important;
        }
    </style>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (document.getElementById('staffTable')) {
                $('#staffTable').DataTable({
                    serverSide: true,
                    processing: true,
                    pageLength: 10,
                    paging: true,
                    searching: false,
                    ordering: true,
                    order: [[0, 'asc']],
                    info: true,
                    language: {
                        url: 'https://cdn.datatables.net/plug-ins/1.13.6/i18n/vi.json'
                    },
                    ajax: {
                        url: '/Staff?handler=StaffList',
                        type: 'GET',
                        data: function (d) {
                            d.search = document.getElementById('staffSearch').value;
                            return d;
                        },
                        dataSrc: 'data',
                        error: function (xhr, status, error) {
                            console.error('DataTables error:', error, xhr);
                        }
                    },
                    columns: [
                        {
                            data: null,
                            render: function (data) {
                                return '<div class="fw-semibold">' + data.fullName + '</div>' +
                                       '<div class="small text-muted">' + data.email + '</div>';
                            },
                            orderable: true
                        },
                        {
                            data: 'specialization',
                            orderable: true
                        },
                        {
                            data: null,
                            render: function (data) {
                                var labels = { 'Doctor': 'Bác sĩ', 'Nurse': 'Y tá', 'Technician': 'Kỹ thuật viên', 'Admin': 'Quản trị' };
                                return labels[data.staffType] || data.staffType;
                            },
                            orderable: true
                        },
                        {
                            data: 'phone',
                            orderable: true
                        },
                        {
                            data: null,
                            render: function (data) {
                                if (data.hasAccount) {
                                    return '<span class="badge bg-success">Đã có</span>';
                                }
                                return '<span class="badge bg-warning text-dark">Chưa có</span>';
                            },
                            orderable: false
                        },
                        {
                            data: null,
                            render: function (data) {
                                if (data.isActive) {
                                    return '<span class="badge bg-success">Hoạt động</span>';
                                }
                                return '<span class="badge bg-secondary">Ngưng</span>';
                            },
                            orderable: true
                        },
                        {
                            data: null,
                            render: function (data) {
                                return '<a class="btn btn-sm btn-outline-primary" href="/Staff/Edit?id=' + data.id + '">Edit</a>';
                            },
                            orderable: false,
                            searchable: false
                        }
                    ],
                    dom: '<"row"<"col-sm-12"f>>rt<"row"<"col-sm-12"<"dataTables_length"l><"dataTables_info"i><"dataTables_paginate"p>>>',
                    drawCallback: function (settings) {
                        console.log('Staff DataTables draw complete');
                    }
                });

                var searchTimeout;
                document.getElementById('staffSearch').addEventListener('input', function () {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(function () {
                        $('#staffTable').DataTable().ajax.reload();
                    }, 400);
                });
            }
        });
    </script>
}
