<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DR.VUHUAN</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.4.1/css/responsive.bootstrap5.min.css">
    <!-- Toastr CSS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
</head>
@inject Clinic.Services.Services.Staffs.IStaffService StaffService
@{
    string? _avatarUrl = null;
    if (User.Identity?.IsAuthenticated == true)
    {
        var sidClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
        if (sidClaim is not null && int.TryParse(sidClaim.Value, out var _staffId))
        {
            var _staff = await StaffService.GetByIdAsync(_staffId);
            _avatarUrl = _staff?.AvatarPath;
        }
    }
}
<body>
    <header>
        <nav class="navbar navbar-light bg-white border-bottom">
            <div class="container-fluid">
                <div class="d-flex align-items-center">
                    <button class="btn btn-light me-2 d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasSidebar" aria-controls="offcanvasSidebar">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <a class="navbar-brand fw-bold me-3 d-flex align-items-center" asp-area="" asp-page="/Index">
                        <img src="~/images/dr-vuhuan.svg" alt="DR.VUHUAN" class="logo-img me-2" />
                        <span class="d-none d-sm-inline">DR.VUHUAN</span>
                    </a>
                </div>

                <div class="d-flex align-items-center">
                    <form id="globalPatientSearchForm" class="d-none d-md-flex me-3 align-items-center" role="search" autocomplete="off">
                        <div class="input-group input-group-sm">
                            <input id="globalPatientSearch" class="form-control form-control-sm" type="search" placeholder="Tìm theo tên hoặc SĐT bệnh nhân..." aria-label="Search" name="search">
                            <a class="btn btn-outline-primary btn-sm" href="javascript:void(0)" id="scanBtn" title="Scan mã vạch bệnh nhân">Scan</a>
                        </div>
                    </form>

                    <a class="btn btn-outline-secondary btn-sm me-2 position-relative" href="/Tasks" title="Reminder Tasks">
                        &#9733;
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="taskNotificationBadge" style="font-size: 0.6rem;">
                            3
                        </span>
                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <a class="btn btn-sm dropdown-toggle d-flex align-items-center gap-1 p-1 pe-2 border" href="#" role="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                @if (!string.IsNullOrEmpty(_avatarUrl))
                                {
                                    <img src="@_avatarUrl" alt="Avatar" class="rounded-circle" style="width: 24px; height: 24px; object-fit: cover;" />
                                }
                                else
                                {
                                    <span>👤</span>
                                }
                                @(User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "User")
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                <li>
                                    <span class="dropdown-item" style="cursor: default;">
                                        Role: <strong>@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</strong>
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/Auth/Profile">Profile</a></li>
                                <li><a class="dropdown-item" href="/Auth/Settings">Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" asp-page="/Auth/Logout" style="margin: 0;">
                                        <button type="submit" class="dropdown-item" style="width: 100%; text-align: left;">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" href="/Auth/Login">Đăng nhập</a>
                    }
                </div>
            </div>
        </nav>

        <!-- Sidebar offcanvas for mobile -->
        <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasSidebar" aria-labelledby="offcanvasSidebarLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="offcanvasSidebarLabel">ClinicCare</h5>
                <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0">
                <nav class="nav flex-column p-3">
                    <a class="nav-link" asp-area="" asp-page="/Index">Lịch khám</a>
                    <a class="nav-link" href="/Operations/SurgeryBooking">Đặt lịch mổ</a>
                    <a class="nav-link" href="/Tasks">Reminder Tasks</a>
                    <a class="nav-link" href="/Patients">Patients</a>
                    <a class="nav-link" href="/Staff">Nhân viên</a>
                    <a class="nav-link" href="/Settings">Settings</a>
                </nav>
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <aside class="col-lg-2 d-none d-lg-block bg-white sidebar py-4">
                <nav class="nav flex-column px-2">
                    <a class="nav-link" asp-area="" asp-page="/Index">Lịch khám</a>
                    <a class="nav-link" href="/Operations/SurgeryBooking">Đặt lịch mổ</a>
                    <a class="nav-link" href="/Tasks">Reminder Tasks</a>
                    <a class="nav-link" href="/Patients">Patients</a>
                    <a class="nav-link" href="/Staff">Nhân viên</a>
                    <a class="nav-link" href="">Settings</a>
                </nav>
            </aside>

            <main class="col-12 col-lg-10 py-4">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <footer class="bg-light text-muted mt-auto py-4 border-top">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div>&copy; @DateTime.Now.Year - DR.VUHUAN</div>
            <div class="mt-2 mt-md-0">
                <a class="text-muted me-3" asp-area="" asp-page="/Privacy">Privacy</a>
                <a class="text-muted me-3" href="#">Terms</a>
                <a class="text-muted" href="#">Contact</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Toastr JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        toastr.options = {
        closeButton: true,
        progressBar: true,
        positionClass: 'toast-top-right',
        timeOut: 3000
        };
    </script>
    @if (TempData["SuccessMessage"] is string successMsg)
    {
        <script>toastr.success('@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(successMsg))');</script>
    }
    @if (TempData["ErrorMessage"] is string errorMsg)
    {
        <script>toastr.error('@Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(errorMsg))');</script>
    }

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.4.1/js/dataTables.responsive.min.js"></script>


    <script>
        document.getElementById('scanBtn').addEventListener('click', function () {
        var modal = new bootstrap.Modal(document.getElementById('scanModal'));
        modal.show();

        // Khởi tạo scanner
        let scannerDiv = document.getElementById('scanner');
        scannerDiv.innerHTML = '';
        let html5QrcodeScanner = new Html5Qrcode("scanner");
        html5QrcodeScanner.start(
            { facingMode: "environment" },
            {
                fps: 10,
                qrbox: 250
            },
            function (decodedText, decodedResult) {
                // Khi scan được mã, chuyển trang
                console.log("Decoded text: ", decodedText);
                console.log("encodeURIComponent text: ", encodeURIComponent(decodedText));
                modal.hide();
                window.location.href = "/Patients/Details?barcode=" + encodeURIComponent(decodedText);
            },
            function (errorMessage) {
                console.log("errorMessage: ", errorMessage);
            }
        );
        // Dừng scanner khi đóng modal
        document.getElementById('scanModal').addEventListener('hidden.bs.modal', function () {
            html5QrcodeScanner.stop();
        }, { once: true });
    });

    document.getElementById('globalPatientSearchForm').addEventListener('submit', function(e) {
        e.preventDefault();
        var val = document.getElementById('globalPatientSearch').value.trim();
        if (val.length > 0) {
            window.location.href = '/Patients/Index?search=' + encodeURIComponent(val);
        }
    });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Modal scan barcode -->
    <div class="modal fade" id="scanModal" tabindex="-1" aria-labelledby="scanModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="scanModalLabel">Quét mã vạch bệnh nhân</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div id="scanner" style="width:100%;"></div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
</body>
</html>
