<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DR.VUHUAN</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/custom-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- DataTables CSS -->
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.4.1/css/responsive.bootstrap5.min.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-light bg-white border-bottom">
            <div class="container-fluid">
                <div class="d-flex align-items-center">
                    <button class="btn btn-light me-2 d-lg-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasSidebar" aria-controls="offcanvasSidebar">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                 

                    <a class="navbar-brand fw-bold me-3 d-flex align-items-center" asp-area="" asp-page="/Index">
                        <img src="~/images/dr-vuhuan.svg" alt="DR.VUHUAN" class="logo-img me-2" />
                        <span class="d-none d-sm-inline">DR.VUHUAN</span>
                    </a>
                </div>

                <div class="d-flex align-items-center">
                    <form class="d-none d-md-flex me-3 align-items-center" role="search">
                        <div class="input-group input-group-sm">
                            <input class="form-control form-control-sm" type="search" placeholder="Search by patient name or Id" aria-label="Search">
                            <a class="btn btn-outline-primary btn-sm" href="/Patients/Details?id=123" title="Scan mã vạch bệnh nhân">Scan</a>
                        </div>
                    </form>

                    <a class="btn btn-outline-secondary btn-sm me-2 position-relative" href="/Tasks" title="Reminder Tasks">
                        &#9733;
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="taskNotificationBadge" style="font-size: 0.6rem;">
                            3
                        </span>
                    </a>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="dropdown">
                            <a class="btn btn-primary btn-sm dropdown-toggle" href="#" role="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                👤 @(User.Identity?.Name ?? "User")
                            </a>

                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
                                <li>
                                    <span class="dropdown-item" style="cursor: default;">
                                        Role: <strong>@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "User")</strong>
                                    </span>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" href="/Auth/Profile">Profile</a></li>
                                <li><a class="dropdown-item" href="/Auth/Settings">Settings</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form method="post" asp-page="/Auth/Logout" style="margin: 0;">
                                        <button type="submit" class="dropdown-item" style="width: 100%; text-align: left;">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-sm" href="/Auth/Login">Đăng nhập</a>
                    }
                </div>
            </div>
        </nav>

        <!-- Sidebar offcanvas for mobile -->
        <div class="offcanvas offcanvas-start" tabindex="-1" id="offcanvasSidebar" aria-labelledby="offcanvasSidebarLabel">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="offcanvasSidebarLabel">ClinicCare</h5>
                <button type="button" class="btn-close text-reset" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body p-0">
                <nav class="nav flex-column p-3">
                    <a class="nav-link" asp-area="" asp-page="/Index">Lịch khám</a>
                    <a class="nav-link" href="/Operations/SurgeryBooking">Đặt lịch mổ</a>
                    <a class="nav-link" href="/Tasks">Reminder Tasks</a>
                    <a class="nav-link" href="/Patients">Patients</a>
                    <a class="nav-link" href="/Staff">Nhân viên</a>
                    <a class="nav-link" href="/Settings">Settings</a>
                </nav>
            </div>
        </div>
    </header>

    <div class="container-fluid">
        <div class="row">
            <aside class="col-lg-2 d-none d-lg-block bg-white sidebar py-4">
                <nav class="nav flex-column px-2">
                    <a class="nav-link" asp-area="" asp-page="/Index">Lịch khám</a>
                    <a class="nav-link" href="/Operations/SurgeryBooking">Đặt lịch mổ</a>
                    <a class="nav-link" href="/Tasks">Reminder Tasks</a>
                    <a class="nav-link" href="/Patients">Patients</a>
                    <a class="nav-link" href="/Staff">Nhân viên</a>
                    <a class="nav-link" href="">Settings</a>
                </nav>
            </aside>

            <main class="col-12 col-lg-10 py-4">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <footer class="bg-light text-muted mt-auto py-4 border-top">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center">
            <div>&copy; @DateTime.Now.Year - DR.VUHUAN</div>
            <div class="mt-2 mt-md-0">
                <a class="text-muted me-3" asp-area="" asp-page="/Privacy">Privacy</a>
                <a class="text-muted me-3" href="#">Terms</a>
                <a class="text-muted" href="#">Contact</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- DataTables JS -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.4.1/js/dataTables.responsive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
