@page
@{
    ViewData["Title"] = "Health Record";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Kết quả chẩn đoán / Hồ sơ sức khỏe</h2>
    <div>
        <a class="btn btn-sm btn-outline-secondary me-2" href="/Patients/Details?id=123">Back</a>
    </div>
</div>
<div class="card p-3 mb-4">
    <div class="row">
        <div class="col-12">
            <!-- Nav tabs -->
            <ul class="nav nav-tabs mb-3" id="diagnosisTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="labs-tab" data-bs-toggle="tab" data-bs-target="#labs" type="button" role="tab" aria-controls="labs" aria-selected="true">Khám lâm sàng</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="services-tab" data-bs-toggle="tab" data-bs-target="#services" type="button" role="tab" aria-controls="services" aria-selected="false">Dịch vụ chỉ định</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="prescription-tab" data-bs-toggle="tab" data-bs-target="#prescription" type="button" role="tab" aria-controls="prescription" aria-selected="false">Đơn thuốc</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="treatment-tab" data-bs-toggle="tab" data-bs-target="#treatment" type="button" role="tab" aria-controls="treatment" aria-selected="false">Báo cáo y tế</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="followup-tab" data-bs-toggle="tab" data-bs-target="#followup" type="button" role="tab" aria-controls="followup" aria-selected="false">Theo dõi</button>
                </li>
            </ul>

            <!-- Tab panes -->
            <div class="tab-content">
                <div class="tab-pane fade show active" id="treatment" role="tabpanel" aria-labelledby="treatment-tab">
                    <div class="row">
                        <div class="col-md-8">
                            <h5>Thông tin bệnh nhân</h5>
                            <div class="d-flex align-items-center mb-2">
                                <div>
                                    <div class="fw-semibold">Nguyen Van A</div>
                                    <div class="small text-muted">ID: PT-00123 — 1988-04-12 — Male</div>
                                </div>

                
                            </div>

                            <h6 class="mt-3">Tóm tắt khám</h6>
                            <p class="text-muted">Bác sĩ: Dr. Tran Thi B — 2026-03-05 09:30</p>

                            <h6 class="mt-3">Khám lâm sàng</h6>
                            <ol>
                                <li>Khám toàn thân: tỉnh táo, tiếp xúc tốt</li>
                                <li>Da: màu sắc bình thường, không phù.</li>
                                <li>Nhiệt độ, mạch, huyết áp bình thường.</li>
                            </ol>

                            <h6>Chuẩn đoán</h6>
                            <p>Viêm họng cấp do virus. Không có dấu hiệu biến chứng. Khuyến nghị nghỉ ngơi, bù nước và theo dõi sốt.</p>

                            <h6 class="mt-3">Kế hoạch điều trị</h6>
                            <ol>
                                <li>Chăm sóc triệu chứng, hạ sốt khi cần.</li>
                                <li>Uống nhiều nước, súc miệng nước muối ấm.</li>
                                <li>Tá hẹn kiểm tra lại nếu sốt &gt; 3 ngày hoặc xuất hiện khó thở.</li>
                            </ol>

                            <h6>Dặn dò</h6>
                            <p>Khuyến nghị nghỉ ngơi, bù nước và theo dõi sốt.</p>

                            <h6>Tái khám</h6>
                            <p>Ngày 20/12/2025.</p>
                        </div>

                        <div class="col-md-4">
                            <h6>Chẩn đoán nhanh</h6>
                            <div class="card p-3 mb-3">
                                <div class="fw-semibold">Chuẩn đoán chính</div>
                                <div class="text-muted small">Viêm họng cấp</div>
                            </div>

                            <h6>Triệu chứng chính</h6>
                            <div class="small text-muted">Ho, sốt nhẹ, đau họng</div>

                            <h6 class="mt-3">Ghi chú bác sĩ</h6>
                            <div class="small text-muted">Bệnh nhân được khuyến nghị nghỉ ngơi và theo dõi. Không kê kháng sinh ngay.</div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="services" role="tabpanel" aria-labelledby="services-tab">
                    <h6 class="mb-3">Dịch vụ chỉ định</h6>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Dịch vụ</th>
                                    <th>Mô tả</th>
                                    <th>Ghi chú</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Khám tai mũi họng</td>
                                    <td>Khám lâm sàng chuyên khoa</td>
                                    <td>-</td>
                                </tr>
                                <tr>
                                    <td>Xét nghiệm nhanh</td>
                                    <td>Test virus</td>
                                    <td>Kết quả dương tính</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade" id="labs" role="tabpanel" aria-labelledby="labs-tab">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Nhiệt độ</th>
                                    <th>Huyết áp</th>
                                    <th>Mạch</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>37</td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-3">
                        <a class="btn btn-primary" href="/Visits/NextAppointment?appointmentId=3">Upload</a>
                    </div>
                </div>

                <div class="tab-pane fade" id="imaging" role="tabpanel" aria-labelledby="imaging-tab">
                    <h6 class="mb-3">Kết quả chẩn đoán hình ảnh</h6>
                    @* <p class="text-muted">Không có kết quả hình ảnh chỉ định cho lần khám này.</p> *@
                    <!-- Example image card -->
                    <div class="row">
                        <div class="col-md-6">
                            <div class="card p-2 mb-2">
                                <img src="~/images/473020376_122134386002459489_5010187318207915830_n.jpg" />
                                <div class="small text-muted mt-2">Chest X-ray — 2026-03-05</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="orders" role="tabpanel" aria-labelledby="orders-tab">
                    <h6 class="mb-3">Y lệnh nội trú</h6>
                    <p class="text-muted">Không có y lệnh nội trú cho bệnh nhân này.</p>
                </div>

                <div class="tab-pane fade" id="prescription" role="tabpanel" aria-labelledby="prescription-tab">
                    <h6 class="mb-3">Đơn thuốc</h6>
                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead>
                                <tr>
                                    <th>Thuốc</th>
                                    <th>Liều</th>
                                    <th>Số lượng</th>
                                    <th>Hướng dẫn</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Paracetamol 500mg</td>
                                    <td>1 viên</td>
                                    <td>10</td>
                                    <td>Uống khi sốt, mỗi 4-6 giờ nếu cần</td>
                                </tr>
                                <tr>
                                    <td>Thuốc ho dạng siro</td>
                                    <td>10 ml</td>
                                    <td>1 chai</td>
                                    <td>Uống 3 lần/ngày sau ăn</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <div class="mt-3">
                        <a class="btn btn-primary" href="/Visits/NextAppointment?appointmentId=3">Upload</a>
                    </div>
                </div>

                <div class="tab-pane fade" id="followup" role="tabpanel" aria-labelledby="followup-tab">
                    <h6 class="mb-3">Uống thuốc được 3 ngày</h6>
                    <p class="text-muted">Thuốc đáp ứng tốt.</p>

                    <h6 class="mb-3">Theo dõi — Hình ảnh sau mổ / sau khám</h6>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="card p-2">
                                <img src="~/images/472915922_122134386536459489_2197837183295026075_n.jpg" />
                                <div class="small text-muted mt-2">Hình ảnh sau mổ — 2026-03-08 (Cập nhật: Điều dưỡng Hồng)</div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card p-2">
                                <img src="~/images/473020376_122134386002459489_5010187318207915830_n.jpg" />
                                <div class="small text-muted mt-2">Hình ảnh sau khám — 2026-03-05 (Bác sĩ: Tran Thi B)</div>
                            </div>
                        </div>

                        <div class="col-12 mt-2">
                            <div class="d-flex gap-2">
                                <a class="btn btn-sm btn-outline-primary">Upload image</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
