@page
@{
    ViewData["Title"] = "Next Appointment";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Lịch hẹn kế tiếp</h2>
    <div>
        <a class="btn btn-sm btn-outline-secondary me-2" href="/Patients/Details?id=123">Back to Patient</a>
    </div>
</div>

<div class="card p-3 mb-4">
    <div class="row">
        <div class="col-md-6">
            <h5>Thông tin lịch hẹn</h5>
            <dl class="row">
                <dt class="col-sm-4">Bệnh nhân</dt>
                <dd class="col-sm-8">Nguyen Van A (PT-00123)</dd>

                <dt class="col-sm-4">Bác sĩ</dt>
                <dd class="col-sm-8">Dr. Tran Thi B</dd>

                <dt class="col-sm-4">Ngày giờ</dt>
                <dd class="col-sm-8">2026-03-19 09:30</dd>

                <dt class="col-sm-4">Loại</dt>
                <dd class="col-sm-8">Follow-up</dd>

                <dt class="col-sm-4">Ghi chú</dt>
                <dd class="col-sm-8">Kiểm tra tiến triển, đánh giá triệu chứng</dd>
            </dl>

            <div class="mt-3">
                <a class="btn btn-outline-secondary" href="#">Reschedule</a>
                <a class="btn btn-outline-secondary" href="#">Cancel</a>
            </div>
        </div>

        <div class="col-md-6">
            <h6>Nhắc nhở</h6>
            <p class="small text-muted">Gửi SMS/Email nhắc hẹn 24 giờ trước. Có thể chỉnh thời gian nhắc trong cài đặt.</p>

            <h6 class="mt-3">Liên hệ</h6>
            <div class="small text-muted">Hotline: 090-123-4567 — Email: support@cliniccare.example</div>

            <h6 class="mt-3">Thao tác nhanh</h6>
            <div class="d-grid gap-2">
                <a class="btn btn-outline-primary">Gửi mail nhắc hẹn</a>
                @* <a class="btn btn-outline-secondary">Send Reminder</a> *@
            </div>
        </div>
    </div>
</div>
