        @section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const checkboxes = document.querySelectorAll('.visit-type-filter');
            const rows = document.querySelectorAll('#visitHistoryTable tbody tr');

            function applyFilter() {
                const activeTypes = Array.from(checkboxes)
                    .filter(cb => cb.checked)
                    .map(cb => cb.value);

                rows.forEach(row => {
                    const type = row.dataset.visitType;
                    if (!type) {
                        row.style.display = '';
                        return;
                    }

                    if (activeTypes.length === 0) {
                        row.style.display = 'none';
                    } else {
                        row.style.display = activeTypes.includes(type) ? '' : 'none';
                    }
                });
            }

            checkboxes.forEach(cb => cb.addEventListener('change', applyFilter));
            applyFilter();

            // ===== POST COMPOSER (mockup — no actual save) =====
            const postContent = document.getElementById('postContent');
            const btnPost = document.getElementById('btnPost');
            const postCharCount = document.getElementById('postCharCount');

            if (postContent && btnPost) {
                postContent.addEventListener('input', function () {
                    const len = this.value.trim().length;
                    btnPost.disabled = len === 0;
                    postCharCount.textContent = len > 0 ? `${len} ký tự` : '';
                    // Auto-expand textarea
                    this.style.height = 'auto';
                    this.style.height = Math.min(this.scrollHeight, 160) + 'px';
                });

                btnPost.addEventListener('click', function () {
                    const text = postContent.value.trim();
                    if (!text) return;

                    // Build a new card and prepend (mockup — not saved anywhere)
                    const cardHtml = `
                    <div class="feed-card" data-type="Post">
                        <div class="feed-card-header">
                            <div class="feed-avatar">📝</div>
                            <div class="feed-meta">
                                <div class="feed-author">Bạn</div>
                                <div class="feed-time">Vừa xong · <span class="badge bg-primary badge-sm">Bài viết</span></div>
                            </div>
                        </div>
                        <div class="feed-card-body">
                            <p class="feed-content">${text.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>
                        </div>
                        <div class="feed-card-footer">
                            <span class="text-muted small">${new Date().toISOString().slice(0, 16).replace('T', ' ')}</span>
                        </div>
                    </div>`;

                    const feed = document.getElementById('activityFeed');
                    const firstCard = feed.querySelector('.feed-card');
                    if (firstCard) {
                        firstCard.insertAdjacentHTML('beforebegin', cardHtml);
                    } else {
                        feed.insertAdjacentHTML('afterbegin', cardHtml);
                    }

                    // Reset composer
                    postContent.value = '';
                    postContent.style.height = 'auto';
                    postCharCount.textContent = '';
                    btnPost.disabled = true;
                });

                // Ctrl+Enter to post
                postContent.addEventListener('keydown', function (e) {
                    if (e.ctrlKey && e.key === 'Enter' && !btnPost.disabled) {
                        btnPost.click();
                    }
                });
            }

            // ===== FEED FILTER BUTTONS =====
            let activeFilter = 'all';
            document.querySelectorAll('.feed-filter').forEach(btn => {
                btn.addEventListener('click', function () {
                    document.querySelectorAll('.feed-filter').forEach(b => {
                        b.classList.remove('active', 'btn-outline-primary');
                        b.classList.add('btn-outline-secondary');
                    });
                    this.classList.remove('btn-outline-secondary');
                    this.classList.add('active', 'btn-outline-primary');
                    activeFilter = this.dataset.type;

                    const cards = document.querySelectorAll('#activityFeed .feed-card');
                    cards.forEach(card => {
                        if (activeFilter === 'all' || card.dataset.type === activeFilter) {
                            card.style.display = '';
                        } else {
                            card.style.display = 'none';
                        }
                    });
                });
            });
        });

        // Simple image viewer (lightbox)
        function openImageViewer(src) {
            const overlay = document.createElement('div');
            overlay.className = 'feed-image-viewer';
            overlay.innerHTML = `<div class="feed-image-viewer-backdrop" onclick="this.parentElement.remove()"></div>
                <img src="${src}" class="feed-image-viewer-img" />
                <button class="btn btn-sm btn-light feed-image-viewer-close" onclick="this.parentElement.remove()">&times;</button>`;
            document.body.appendChild(overlay);
        }
    </script>
}
