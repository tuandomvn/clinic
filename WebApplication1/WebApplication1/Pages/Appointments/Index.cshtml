                                        <div class="fw-semibold">Pham Van E</div>
                                        <div class="small text-muted">PT-00789</div>
                                    </div>
                                </div>
                            </td>
                            <td>Dr. Lab Tech</td>
                            <td>Lab test</td>
                            <td>Lab A</td>
                            <td><span class="badge bg-warning text-dark">In lab</span></td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="/Visits/HealthRecord?appointmentId=4">Details</a>
                            </td>
                        </tr>
                        <tr>
                            <td>10:00</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="https://via.placeholder.com/44" class="rounded-circle me-2" alt="">
                                    <div>
                                        <div class="fw-semibold">Le Thi C</div>
                                        <div class="small text-muted">PT-00456</div>
                                    </div>
                                </div>
                            </td>
                            <td>Dr. Nguyen Van D</td>
                            <td>Follow-up</td>
