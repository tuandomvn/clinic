@page
@{
    ViewData["Title"] = "Appointments";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Appointments</h2>
    <div>
        <a class="btn btn-sm btn-primary" href="/Appointments/Create">New Appointment</a>
    </div>
</div>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-4">
            <input class="form-control" placeholder="Search by patient name or ID" />
        </div>
        <div class="col-md-2">
            <input type="date" class="form-control" />
        </div>
        <div class="col-md-2">
            <select class="form-select">
                <option>All doctors</option>
                <option>Dr. Tran Thi B</option>
                <option>Dr. Nguyen Van D</option>
            </select>
        </div>
        <div class="col-md-2">
            <select class="form-select">
                <option>All types</option>
                <option>Check-up</option>
                <option>Follow-up</option>
                <option>Emergency</option>
            </select>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-12">
        <div class="card p-3">
            <h5 class="mb-3">Appointment List</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Patient</th>
                            <th>Doctor</th>
                            <th>Type</th>
                            <th>Location</th>
                            <th>Status</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>09:30</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="https://via.placeholder.com/44" class="rounded-circle me-2" alt="">
                                    <div>
                                        <div class="fw-semibold">Nguyen Van A</div>
                                        <div class="small text-muted">PT-00123</div>
                                    </div>
                                </div>
                            </td>
                            <td>Dr. Tran Thi B</td>
                            <td>Check-up</td>
                            <td>Room 201</td>
                            <td><span class="badge bg-info">In consultation</span></td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="/Visits/HealthRecord?appointmentId=1">Details</a>
                            </td>
                        </tr>
                        <tr>
                            <td>09:45</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <img src="https://via.placeholder.com/44" class="rounded-circle me-2" alt="">
