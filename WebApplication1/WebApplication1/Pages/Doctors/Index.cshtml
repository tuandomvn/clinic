@page
@{
    ViewData["Title"] = "Doctors";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Doctors</h2>
    <div>
        <a class="btn btn-sm btn-primary" href="/Doctors/Create">Add Doctor</a>
    </div>
</div>

<div class="card mb-3 p-3">
    <div class="row g-3 align-items-center">
        <div class="col-md-5">
            <input class="form-control" placeholder="Search by name or specialty" />
        </div>
        <div class="col-md-3">
            <select class="form-select">
                <option>All specialties</option>
                <option>General</option>
                <option>Pediatrics</option>
                <option>Cardiology</option>
            </select>
        </div>
        <div class="col-md-4 text-end">
            <a class="btn btn-outline-secondary btn-sm me-2">Import</a>
            <a class="btn btn-outline-secondary btn-sm">Export</a>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        <div class="card p-3 text-center">
            <img src="~/images/bac si 1.png" />

            <h5 class="mb-0">Dr. Tran Thi B</h5>
            <div class="small text-muted">General Practitioner</div>
            <div class="mt-3">
                <a class="btn btn-sm btn-outline-primary me-1" href="/Doctors/Shifts?id=1">Manage Shifts</a>
                <a class="btn btn-sm btn-outline-secondary" href="#">Profile</a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card p-3">
            <h5 class="mb-3">Doctor Directory</h5>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Doctor</th>
                            <th>Specialty</th>
                            <th>Available</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div>
                                        <div class="fw-semibold">Dr. Tran Thi B</div>
                                        <div class="small text-muted">DR-0001</div>
                                    </div>
                                </div>
                            </td>
                            <td>General Practitioner</td>
                            <td>Mon-Fri</td>
                                <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="/Doctors/Edit?id=1">Edit</a>
                                <a class="btn btn-sm btn-outline-secondary" href="/Doctors/Shifts?id=1">Shifts</a>
                            </td>
                        </tr>
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div>
                                        <div class="fw-semibold">Dr. Nguyen Van D</div>
                                        <div class="small text-muted">DR-0002</div>
                                    </div>
                                </div>
                            </td>
                            <td>Cardiology</td>
                            <td>Tue, Thu</td>
                            <td>
                                <a class="btn btn-sm btn-outline-primary me-1" href="#">Edit</a>
                                <a class="btn btn-sm btn-outline-secondary" href="/Doctors/Shifts?id=1">Shifts</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
