@page "{id?}"
@{
    ViewData["Title"] = "Doctor Shifts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Doctor Shift Management</h2>
    <div>
        <a class="btn btn-sm btn-outline-secondary me-2" href="/Doctors">Back to Doctors</a>
    </div>
</div>

<div class="card p-3 mb-4">
    <div class="row">
        <div class="col-md-4">
            <div class="d-flex align-items-center mb-3">
                <img src="https://via.placeholder.com/80" class="rounded-circle me-3" alt="doctor" />
                <div>
                    <div class="fw-semibold">Dr. Tran Thi B</div>
                    <div class="small text-muted">ID: DR-0001 — General Practitioner</div>
                </div>
            </div>

            <h6 class="mb-2">Upcoming Shifts</h6>
            <ul class="list-group mb-3">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold">2026-03-19 — Morning</div>
                        <div class="small text-muted">08:00 — 12:00 — Room 201</div>
                    </div>
                    <div>
                        <a class="btn btn-sm btn-outline-secondary">Edit</a>
                    </div>
                </li>
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                        <div class="fw-semibold">2026-03-20 — Afternoon</div>
                        <div class="small text-muted">13:00 — 17:00 — Room 201</div>
                    </div>
                    <div>
                        <a class="btn btn-sm btn-outline-secondary">Edit</a>
                    </div>
                </li>
            </ul>

            <h6 class="mb-2">Quick actions</h6>
            <div class="d-grid gap-2">
                <a class="btn btn-outline-primary" href="#addShift">Add Shift</a>
                <a class="btn btn-outline-secondary" href="#">Export Schedule</a>
            </div>
        </div>

        <div class="col-md-8">
            <h6 class="mb-3">Weekly overview</h6>
            <div class="card p-3 mb-3">
                <!-- Placeholder for small calendar / timetable -->
                <img src="https://via.placeholder.com/760x200?text=Weekly+Timetable+Preview" class="img-fluid rounded" alt="timetable" />
            </div>

            <h6 class="mb-2">Create / Edit Shift</h6>
            <form id="addShift">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Start time</label>
                        <input type="time" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">End time</label>
                        <input type="time" class="form-control" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Location / Room</label>
                        <input class="form-control" placeholder="e.g. Room 201 / Lab A" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Shift type</label>
                        <select class="form-select">
                            <option>Morning</option>
                            <option>Afternoon</option>
                            <option>Evening</option>
                            <option>On-call</option>
                        </select>
                    </div>

                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="recurring" />
                            <label class="form-check-label small" for="recurring">Recurring weekly</label>
                        </div>
                    </div>

                    <div class="col-12 d-flex gap-2 mt-2">
                        <button type="button" class="btn btn-primary">Save Shift</button>
                        <button type="reset" class="btn btn-outline-secondary">Reset</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
